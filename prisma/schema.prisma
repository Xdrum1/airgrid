datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Auth.js required models ─────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  firstName             String?
  lastName              String?
  organization          String?
  jobTitle              String?
  buyerType             String?   // infra-developer|operator|municipality|heliport-owner|insurance|federal|other
  referralSource        String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  stripeCustomerId      String?   @unique
  tier                  String    @default("free") // free|pro|institutional|enterprise|grandfathered
  role                  String?   // legacy — kept for existing data
  accounts              Account[]
  sessions              Session[]
  subscriptions         Subscription[]
  billingSubscriptions  BillingSubscription[]
  watchlist             Watchlist?
  events                UserEvent[]
  apiKeys               ApiKey[]
  loginEvents           LoginEvent[]
  newsletterOptOut      Boolean   @default(false)
  lastActiveAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── App models ──────────────────────────────────────────────

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  cityIds      String[]
  corridorIds  String[] @default([])
  changeTypes  String[]
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  cityIds   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoreSnapshot {
  id                String   @id @default(cuid())
  cityId            String
  score             Int
  breakdown         Json
  tier              String?  // "HIGH" | "MODERATE" | "EARLY" | "NASCENT"
  triggeringEventId String?  // links to ChangelogEntry.id
  filingIngestedAt  DateTime? // when the triggering filing was first ingested
  capturedAt        DateTime @default(now())

  @@index([cityId, capturedAt])
}

model ClassificationResult {
  id             String   @id @default(cuid())
  recordId       String   // IngestedRecord.id
  eventType      String   // from the event_type vocabulary
  factorsJson    Json     // full factors_affected array from Claude
  affectedCities String[] // city IDs identified
  confidence     String   // "high" | "medium" | "needs_review"
  rawResponse    Json     // full Claude API response for debugging
  modelUsed      String   // e.g. "claude-haiku-4-5-20251001"
  promptVersion  String   // version string for prompt tracking
  createdAt      DateTime @default(now())

  @@index([recordId])
  @@index([eventType])
  @@index([confidence])
}

model ChangelogEntry {
  id                String   @id @default(cuid())
  changeType        String   // "new_filing" | "status_change" | "new_law" | "faa_update" | "score_change"
  relatedEntityType String   // "city" | "vertiport" | "operator" | "corridor" | "filing"
  relatedEntityId   String
  summary           String
  sourceUrl         String?
  timestamp         DateTime @default(now())

  @@index([timestamp])
  @@index([changeType])
}

model Corridor {
  id                    String    @id // e.g. "cor_lax_dtla"
  name                  String
  status                String    // "proposed" | "authorized" | "active" | "suspended"
  cityId                String
  operatorId            String?
  startPointLat         Float
  startPointLng         Float
  startPointLabel       String
  endPointLat           Float
  endPointLng           Float
  endPointLabel         String
  waypoints             Json?     // Array of { lat, lng }
  distanceKm            Float
  estimatedFlightMinutes Int
  maxAltitudeFt         Int
  altitudeMinFt         Int?
  faaAuthNumber         String?
  effectiveDate         String?
  expirationDate        String?
  clearedOperators      String[]
  notes                 String?
  sourceUrl             String?
  lastUpdated           DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  statusHistory CorridorStatusHistory[]

  @@index([cityId])
  @@index([status])
  @@index([operatorId])
}

model CorridorStatusHistory {
  id          String    @id @default(cuid())
  corridorId  String
  fromStatus  String?
  toStatus    String
  reason      String?
  sourceUrl   String?
  changedAt   DateTime  @default(now())

  corridor    Corridor  @relation(fields: [corridorId], references: [id], onDelete: Cascade)

  @@index([corridorId, changedAt])
}

model UserEvent {
  id         String   @id @default(cuid())
  userId     String
  event      String   // "page_view" | "city_detail" | "corridor_click" | "tab_switch" | "report_download" | "operator_click"
  entityType String?  // "city" | "corridor" | "operator" | "page" | "tab" | "report"
  entityId   String?  // e.g. "los_angeles", "cor_mia_fll", "/methodology"
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([event])
  @@index([entityType, entityId])
}

model ScoringOverride {
  id             String    @id @default(cuid())
  cityId         String
  field          String    // scoring input name (e.g. "hasStateLegislation")
  value          Json      // the override value (e.g. true)
  reason         String
  sourceRecordId String?   // links to IngestedRecord.id
  sourceUrl      String?
  confidence     String    // "high" | "medium" | "needs_review"
  appliedAt      DateTime? // set when auto-applied
  supersededAt   DateTime? // set when a newer override replaces this one
  createdAt      DateTime  @default(now())

  @@index([cityId, field])
}

model AutoReviewResult {
  id              String   @id @default(cuid())
  overrideId      String
  decision        String   // "approve" | "reject" | "skip"
  confidence      Float
  assignedCityId  String?  // city assigned for __unresolved__ overrides
  reasoning       String
  applied         Boolean  // whether the decision was actually applied
  dryRun          Boolean  @default(false)
  modelUsed       String
  sourceContent   String?  // truncated source text if fetched
  createdAt       DateTime @default(now())

  @@index([overrideId])
  @@index([decision])
  @@index([createdAt])
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  role      String?
  tier      String   // "pro" | "institutional" | "enterprise"
  message   String?
  status    String   @default("new") // new | contacted | qualified | converted | closed
  notes     String?  // admin notes for follow-up tracking
  source    String?  // ref param from contact form (e.g. "breakdown", "alerts", "api")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([tier])
  @@index([email])
  @@index([status])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  tier       String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BillingSubscription {
  id                    String    @id @default(cuid())
  userId                String
  stripeCustomerId      String
  stripeSubscriptionId  String    @unique
  stripePriceId         String
  tier                  String    // pro|institutional|enterprise
  status                String    // active|past_due|canceled|trialing|unpaid
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean   @default(false)
  canceledAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([status])
}

model IngestedRecord {
  id          String   @id // e.g. "federal_register_FR2023..."
  source      String   // "federal_register" | "legiscan" | "sec_edgar" | "operator_news"
  sourceId    String
  title       String
  summary     String
  status      String
  date        String
  url         String
  state       String?
  raw         Json
  ingestedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source])
}

model IngestionRun {
  id              String   @id @default(cuid())
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  newRecords      Int      @default(0)
  updatedRecords  Int      @default(0)
  unchangedCount  Int      @default(0)
  totalRecords    Int      @default(0)
  sources         String[] // ["federal_register", "legiscan", ...]
  overridesCreated Int     @default(0)
  overridesApplied Int     @default(0)
  scoreChanges    Int      @default(0)
  error           String?  // null = success, else error message
  alertSent       Boolean  @default(false)

  @@index([startedAt])
}

// ── Market Watch (ratings agency layer) ─────────────────────

model MarketWatch {
  id          String    @id @default(cuid())
  cityId      String    @unique
  watchStatus String    @default("STABLE") // STABLE | POSITIVE_WATCH | NEGATIVE_WATCH | DEVELOPING
  outlook     String    @default("STABLE") // IMPROVING | STABLE | DETERIORATING
  analystNote String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  history MarketWatchHistory[]

  @@index([watchStatus])
  @@index([published])
}

model MarketWatchHistory {
  id              String    @id @default(cuid())
  marketWatchId   String
  cityId          String
  fromWatchStatus String?
  toWatchStatus   String
  fromOutlook     String?
  toOutlook       String
  analystNote     String?
  reason          String
  source          String    @default("admin") // "admin" | "ai_suggested"
  suggestedBy     String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())

  marketWatch MarketWatch @relation(fields: [marketWatchId], references: [id], onDelete: Cascade)

  @@index([cityId, createdAt])
  @@index([marketWatchId])
}

model MarketWatchSuggestion {
  id               String   @id @default(cuid())
  cityId           String
  suggestedStatus  String
  suggestedOutlook String
  reasoning        String
  confidence       Float
  signalCount      Int
  status           String   @default("pending") // pending | accepted | dismissed
  createdAt        DateTime @default(now())

  @@index([cityId])
  @@index([status])
}

// ── Automated Watch List (pipeline-driven) ──────────────

model WatchListEntry {
  id               String    @id @default(cuid())
  cityId           String
  triggerType       String    // LEGISLATION | PIPELINE_OVERRIDE | ELEVATED_ACTIVITY
  triggerDetail     String    // human-readable description
  currentScore      Int       // score at time of trigger
  triggeredAt       DateTime  @default(now())
  resolvedAt        DateTime? // null if still active
  resolutionReason  String?   // SCORE_CHANGED | SIGNAL_RESOLVED | MANUAL_REMOVE

  @@index([cityId])
  @@index([triggerType])
  @@index([resolvedAt])
}

// ── Intel Feed ──────────────────────────────────────────

model FeedItem {
  id                     String    @id @default(cuid())
  slug                   String?   @unique
  title                  String
  summary                String    // 1-2 editorial sentences
  sourceUrl              String?
  category               String    // "Regulatory" | "Infrastructure" | "Operator" | "Legislative"
  cityIds                String[]  // tracked market city IDs
  scoreImpact            Boolean   @default(false)
  status                 String    @default("draft") // "draft" | "published" | "archived"
  promotedBy             String?   // "admin" | "auto"
  sourceRecordId         String?   // optional link to IngestedRecord.id
  classificationResultId String?   // optional link to ClassificationResult.id
  publishedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([category])
}

model MarketLead {
  id              String    @id @default(cuid())
  city            String    // e.g. "Columbus"
  state           String    // e.g. "OH"
  country         String    @default("US")
  source          String    // who tipped it — e.g. "Mike", "Rex", "SEC filing", "news"
  signal          String    // what they said / what was observed
  status          String    @default("new") // new | researching | verified | added | dismissed
  priority        String    @default("normal") // low | normal | high
  researchNotes   String?   // running notes on 7-factor research
  factorSnapshot  Json?     // partial scoring assessment: { hasStateLegislation: true, ... }
  addedAsCityId   String?   // set when graduated to live market (links to city id in seed)
  dismissedReason String?   // why it was dismissed
  signalCount     Int       @default(1)      // number of distinct signals accumulated
  lastSignalAt    DateTime? // when the most recent signal was detected
  signalSources   Json?     // array of { source, url, date, summary } for audit trail
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([city, state, country])
  @@index([status])
  @@index([priority])
}

// ── FAA Heliport Data (NASR 5010) ────────────────────────

model Heliport {
  id              String   @id // FAA Location Identifier (e.g. "0LA1")
  facilityName    String
  city            String
  state           String
  county          String?
  ownershipType   String   // "PU" (public) | "PR" (private) | "MA" (Air Force) | "MN" (Navy) | "MR" (Army)
  useType         String   // "PU" (public use) | "PR" (private use)
  lat             Float
  lng             Float
  elevation       Float?   // feet MSL
  statusCode      String   // "O" (operational) | "CI" (closed indefinitely) | "CP" (closed permanently)
  certTypeDate    String?  // certification type
  airportOfEntry  String?
  federalAgreement String?
  airspaceAnalysis String?
  basedAircraft   Int?
  annualOps       Int?
  cityId          String?  // mapped AirIndex market ID (null if not in tracked metro)
  ingestedAt      DateTime @default(now())

  @@index([cityId])
  @@index([state])
  @@index([ownershipType])
  @@index([statusCode])
}

// ── Event-Driven Signal Layer (Phase 2) ─────────────────

model SignalEvent {
  id         String    @id @default(cuid())
  source     String    // "federal_register" | "legiscan" | "sec_edgar" | "operator_news"
  cityId     String
  eventType  String    // regulatory_filing | legislative_activity | operator_announcement | faa_update
  title      String
  sourceUrl  String?
  confidence String    // "high" | "medium" | "needs_review"
  rawRecord  Json      // original record data for audit
  detectedAt DateTime  @default(now())
  notifiedAt DateTime? // when Pro+ subscribers were notified (null = pending)

  @@index([cityId, detectedAt])
  @@index([source])
  @@index([eventType])
  @@index([confidence, detectedAt])
}

// ── Emerging Markets Stealth Pipeline ────────────────────

model EmergingMarketSignal {
  id           String   @id @default(cuid())
  marketName   String   // e.g. "Nuclear SMR", "Commercial Drone", "Hydrogen Fueling"
  sourceId     String   // unique ID from source API
  title        String
  url          String
  source       String   // "doe_arpa_e" | "clinicaltrials_gov" | "nrc_adams" | ...
  relevant     Boolean
  signalType   String   // regulatory_filing | legislative_activity | grant_award | patent_filing | investment_round | research_publication | other
  momentum     String   // positive | negative | neutral
  raw          Json     // full API response for audit
  classifiedAt DateTime
  ingestedAt   DateTime @default(now())

  // Classification audit trail — same discipline as AirIndex ClassificationResult
  promptVersion     String?  // e.g. "emerging-v1"
  modelUsed         String?  // e.g. "claude-haiku-4-5-20251001"
  confidence        String?  // "high" | "medium" | "low" — classifier self-assessed confidence
  rawClassification Json?    // full Claude API response for reproducibility audit

  @@unique([source, sourceId])
  @@index([marketName])
  @@index([source])
  @@index([signalType])
  @@index([relevant, ingestedAt])
}

// ── Login Device Tracking ────────────────────────────────

model LoginEvent {
  id              String    @id @default(cuid())
  userId          String
  ip              String
  userAgent       String?
  fingerprintHash String    // SHA-256 of (userAgent + IP /24 subnet)
  deviceType      String?   // "Desktop" | "Mobile" | "Tablet" | "Unknown"
  browser         String?   // "Chrome 120" | "Safari 17" etc.
  os              String?   // "macOS 14" | "Windows 11" etc.
  isNewDevice     Boolean   @default(false)
  notifiedAt      DateTime? // when notification email was sent
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, fingerprintHash])
  @@index([userId, createdAt])
}

// ── Newsletter Tracking ──────────────────────────────────

model NewsletterEvent {
  id        String   @id @default(cuid())
  email     String
  issue     Int
  event     String   // "open" | "click"
  url       String?  // destination URL for click events
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([email, issue])
  @@index([issue, event])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════════════════
// MCS — Market Context Store (Foundation)
// Canonical market registry. Every container references
// Market.id as the stable city identifier.
// ═══════════════════════════════════════════════════════════

model Market {
  id            String   @id                     // Matches seed.ts city IDs (e.g. "los_angeles")
  city          String                           // "Los Angeles"
  state         String   @db.Char(2)             // "CA"
  metro         String?                          // "Greater Los Angeles"
  country       String   @default("US") @db.Char(2)
  lat           Decimal  @db.Decimal(9, 6)
  lng           Decimal  @db.Decimal(9, 6)
  isActive      Boolean  @default(true)
  addedAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt

  factorScores  FkbFactorScore[]
  ordinanceAudit OrdinanceAudit?

  @@index([state])
  @@index([isActive])
}

// ── Municipality Ordinance Audit Data ────────────────────
// Manual-seed table: 5 compliance questions per market.
// Populated by Alan, imported by dev. Updated as ordinances change.

model OrdinanceAudit {
  id                    String   @id @default(cuid())
  marketId              String   @unique
  market                Market   @relation(fields: [marketId], references: [id])
  faaTerminology        String   @default("unknown") // yes | no | partial | unknown
  faaTerminologyNote    String?  @db.Text
  zoningOrdinance       String   @default("unknown") // yes | no | partial | unknown
  zoningOrdinanceNote   String?  @db.Text
  airspaceDetermination String   @default("unknown") // yes | no | partial | unknown
  airspaceDeterminationNote String? @db.Text
  nfpa418Referenced     String   @default("unknown") // yes | no | partial | unknown
  nfpa418ReferencedNote String?  @db.Text
  stateAdoptedAC        String   @default("unknown") // yes | no | partial | unknown
  stateAdoptedACNote    String?  @db.Text
  lastAuditedAt         DateTime? @db.Date
  auditedBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
// FKB — Factor Knowledge Base (Container 1)
// Authoritative source of truth for scoring factors, weights,
// data sources, per-market factor scores, and analyst overrides.
// Hard rule: no deletes. Retire factors, deprecate sources,
// log overrides — never DELETE.
// ═══════════════════════════════════════════════════════════

model FkbFactor {
  id               String   @id @default(cuid())
  code             String   @unique              // OPR, LEG, VRT, REG, PLT, ZON, MKT
  name             String                        // "Operator Presence"
  description      String   @db.Text             // Canonical definition
  scoringTier      String                        // PRIMARY | DERIVED | BINARY
  introducedIn     String                        // Methodology version (e.g. "v1.0")
  retired          Boolean  @default(false)
  retiredIn        String?                       // Version retired (e.g. "v1.3" for LAANC)
  retirementReason String?  @db.Text
  sortOrder        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  weights          FkbFactorWeight[]
  sources          FkbFactorSource[]
  scores           FkbFactorScore[]
}

model FkbFactorWeight {
  id               String   @id @default(cuid())
  factorId         String
  factor           FkbFactor @relation(fields: [factorId], references: [id])
  methodologyVersion String                     // "v1.3"
  weightPct        Decimal  @db.Decimal(5, 2)    // 0-100 weight
  effectiveFrom    DateTime @db.Date
  effectiveTo      DateTime? @db.Date            // NULL = currently active
  changeRationale  String   @db.Text
  approvedBy       String                        // Name/title of approver
  createdAt        DateTime @default(now())

  @@index([factorId, methodologyVersion])
  @@index([effectiveFrom])
}

model FkbFactorSource {
  id               String   @id @default(cuid())
  factorId         String
  factor           FkbFactor @relation(fields: [factorId], references: [id])
  sourceName       String                        // "Federal Register API"
  sourceType       String                        // API | RSS | SCRAPE | MANUAL | UPLOAD
  baseUrl          String?  @db.Text
  apiEndpoint      String?  @db.Text
  reliabilityScore Int      @db.SmallInt          // 1-5: 5=federal official, 1=press/social
  updateFrequency  String                        // DAILY | WEEKLY | MONTHLY | ON_EVENT
  lastVerified     DateTime? @db.Date
  isActive         Boolean  @default(true)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([factorId])
  @@index([isActive])
}

model FkbFactorScore {
  id                  String   @id @default(cuid())
  factorId            String
  factor              FkbFactor @relation(fields: [factorId], references: [id])
  marketId            String
  market              Market   @relation(fields: [marketId], references: [id])
  score               Decimal  @db.Decimal(5, 2)  // Raw factor score
  scoreNormalized     Decimal  @db.Decimal(5, 2)  // Scaled to 0-100 contribution range
  methodologyVersion  String
  confidence          String                     // HIGH | MEDIUM | LOW
  confidenceReasons   Json?                      // [{reason, impact}]
  signalCount         Int      @default(0)
  hasOverride         Boolean  @default(false)
  scoredAt            DateTime @default(now())

  overrides           FkbScoreOverride[]

  @@unique([factorId, marketId, methodologyVersion])
  @@index([marketId])
  @@index([confidence])
}

model FkbScoreOverride {
  id                  String   @id @default(cuid())
  factorScoreId       String
  factorScore         FkbFactorScore @relation(fields: [factorScoreId], references: [id])
  originalScore       Decimal  @db.Decimal(5, 2)
  overrideScore       Decimal  @db.Decimal(5, 2)
  overrideReason      String   @db.Text
  evidenceUrl         String?  @db.Text
  overrideType        String                     // UPWARD | DOWNWARD
  overrideConfidence  String                     // HIGH | MEDIUM
  analystName         String
  reviewedBy          String?                    // Second reviewer for magnitude >5
  expiresAt           DateTime? @db.Date          // Auto-flag for re-evaluation
  createdAt           DateTime @default(now())

  @@index([factorScoreId])
}

model FkbMethodologyVersion {
  id               String   @id @default(cuid())
  version          String   @unique              // "v1.0", "v1.3", etc.
  effectiveDate    DateTime @db.Date
  summary          String   @db.Text             // Human-readable changelog
  factorsAdded     String[] @default([])          // Factor codes added
  factorsRetired   String[] @default([])          // Factor codes retired
  weightsChanged   Json?                         // [{factorCode, oldWeight, newWeight}]
  approvedBy       String
  createdAt        DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════
// OID — Operator Intelligence Database (Container 3)
// Structured intelligence about every eVTOL/UAM operator.
// Feeds OPR factor scoring. Standalone API product for
// Institutional/Enterprise tiers.
// Hard rule: no deletes. Operators marked is_active=FALSE.
// Market presence records for EXITED retained as history.
// ═══════════════════════════════════════════════════════════

model OidOperator {
  id                String   @id @default(cuid())
  name              String   @db.VarChar(200)      // Legal/operating name
  shortName         String   @db.VarChar(50)       // Display name (e.g. "Joby")
  ticker            String?  @db.VarChar(10)       // Stock ticker if public
  cik               String?  @db.VarChar(20)       // SEC CIK number
  entityType        String   @db.VarChar(30)       // MANUFACTURER | OPERATOR | OPERATOR_MANUFACTURER | INFRASTRUCTURE
  vehicleType       String?  @db.VarChar(50)       // eVTOL | eSTOL | VTOL | HYBRID
  hqCity            String?  @db.VarChar(100)
  hqCountry         String   @default("US") @db.Char(2)
  foundedYear       Int?     @db.SmallInt
  website           String?  @db.Text
  isActive          Boolean  @default(true)
  inactiveReason    String?  @db.Text              // Acquisition, bankruptcy, pivot
  acquiredBy        String?                        // Self-referential — OidOperator.id
  oprWeightMultiplier Decimal @default(1.0) @db.Decimal(3, 2) // Analyst-adjustable
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  marketPresence    OidOperatorMarketPresence[]
  events            OidOperatorEvent[]
  certifications    OidOperatorCertification[]
  financing         OidOperatorFinancing[]
  vertiportCommitments OidVertiportCommitment[]

  @@index([entityType])
  @@index([isActive])
}

model OidOperatorMarketPresence {
  id               String   @id @default(cuid())
  operatorId       String
  operator         OidOperator @relation(fields: [operatorId], references: [id])
  cityId           String                         // References Market.id
  deploymentStage  String   @db.VarChar(20)       // COMMERCIAL_OPS | CERTIFIED | TESTING | ANNOUNCED | WATCHLIST | EXITED
  stageScore       Int      @db.SmallInt           // 20 | 15 | 10 | 5 | 2 | 0
  stageSetAt       DateTime @db.Date
  stageSetBy       String   @db.VarChar(20)       // PIPELINE | ANALYST
  evidenceEventId  String?                        // References OidOperatorEvent.id
  confidence       String   @db.VarChar(10)       // HIGH | MEDIUM | LOW
  notes            String?  @db.Text
  routeAnnounced   Boolean  @default(false)
  vertiportCommitted Boolean @default(false)
  isActive         Boolean  @default(true)        // FALSE if operator exited market
  lastSignalAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([operatorId, cityId])
  @@index([cityId])
  @@index([deploymentStage])
  @@index([isActive])
}

model OidOperatorEvent {
  id                    String   @id @default(cuid())
  operatorId            String
  operator              OidOperator @relation(fields: [operatorId], references: [id])
  cityId                String?                   // NULL for company-wide events
  eventType             String   @db.VarChar(30)   // 20-type taxonomy
  eventDate             DateTime @db.Date
  headline              String   @db.VarChar(300)
  sourceName            String   @db.VarChar(100)
  sourceUrl             String?  @db.Text
  sourceReliability     Int      @db.SmallInt       // 1-5
  stageImplication      String?  @db.VarChar(20)   // Which deployment stage this implies
  stageImplicationConfidence String? @db.VarChar(10) // HIGH | MEDIUM | LOW
  rawSignalId           String?                    // Pipeline signal link
  isVerified            Boolean  @default(false)
  verifiedBy            String?  @db.VarChar(100)
  ingestedAt            DateTime @default(now())

  @@index([operatorId])
  @@index([cityId])
  @@index([eventType])
  @@index([eventDate])
}

model OidOperatorCertification {
  id               String   @id @default(cuid())
  operatorId       String
  operator         OidOperator @relation(fields: [operatorId], references: [id])
  certType         String   @db.VarChar(30)       // FAA_PART135 | FAA_TYPE_CERT | FAA_EXPERIMENTAL | FAA_ATCO | FAA_BEYOND | OTHER
  certNumber       String?  @db.VarChar(100)
  issuingAuthority String   @db.VarChar(100)
  cityId           String?                        // Market-specific cert, NULL for national
  issuedDate       DateTime? @db.Date
  effectiveDate    DateTime? @db.Date
  expiryDate       DateTime? @db.Date
  isActive         Boolean  @default(true)
  sourceUrl        String?  @db.Text
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([operatorId])
  @@index([certType])
}

model OidOperatorFinancing {
  id               String   @id @default(cuid())
  operatorId       String
  operator         OidOperator @relation(fields: [operatorId], references: [id])
  roundType        String   @db.VarChar(30)       // SEED | SERIES_A | SERIES_B | SERIES_C | DEBT | SPAC | IPO | GRANT | STRATEGIC
  amountUsd        Decimal? @db.Decimal(15, 2)
  amountDisclosed  Boolean  @default(true)
  announcedDate    DateTime @db.Date
  closedDate       DateTime? @db.Date
  leadInvestor     String?  @db.VarChar(200)
  notableInvestors String[] @default([])
  totalRaisedToDate Decimal? @db.Decimal(15, 2)
  sourceName       String   @db.VarChar(100)
  sourceUrl        String?  @db.Text
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([operatorId])
  @@index([roundType])
  @@index([announcedDate])
}

model OidVertiportCommitment {
  id               String   @id @default(cuid())
  operatorId       String
  operator         OidOperator @relation(fields: [operatorId], references: [id])
  cityId           String                         // References Market.id
  commitmentType   String   @db.VarChar(30)       // GROUND_LEASE | MOU | LOI | PARTNERSHIP | OWNERSHIP
  siteName         String?  @db.VarChar(200)
  partnerName      String?  @db.VarChar(200)      // Airport authority, developer, etc.
  announcedDate    DateTime @db.Date
  sourceUrl        String?  @db.Text
  isActive         Boolean  @default(true)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([operatorId])
  @@index([cityId])
}

// ═══════════════════════════════════════════════════════════
// RPL — Regulatory Precedent Library (Container 4)
// Structured repository of regulatory documents, legislative
// records, and administrative rulings. Evidence layer for
// REG + LEG scoring. Training corpus for Prediction Layer.
// Hard rule: nothing is ever deleted. Append-only.
// ═══════════════════════════════════════════════════════════

model RplDocument {
  id                  String   @id @default(cuid())
  docType             String                     // FEDERAL_RULE, STATE_BILL, etc. (15 types)
  title               String   @db.VarChar(500)
  shortTitle          String?  @db.VarChar(200)   // Human-readable for watch list
  issuingAuthority    String   @db.VarChar(100)   // "FAA", "LegiScan / Texas Legislature"
  documentNumber      String?  @db.VarChar(100)   // Docket, bill number, order number
  publishedDate       DateTime @db.Date
  effectiveDate       DateTime? @db.Date          // When enacted/effective
  momentumDirection   String   @db.Char(3)        // POS | NEG | NEU | MIX
  significance        String                     // HIGH | MEDIUM | LOW
  summary             String?  @db.Text           // AI-generated or analyst summary
  sourceUrl           String?  @db.Text
  storageKey          String?  @db.Text           // S3 key for full-text body
  storageFetchedAt    DateTime?
  rawSignalId         String?                    // Link to pipeline signal if originated there
  isActive            Boolean  @default(true)     // FALSE if withdrawn/superseded/vetoed
  supersededBy        String?                    // Self-referential FK
  ingestedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  factorMappings      RplDocumentFactorMapping[]
  cityAssociations    RplDocumentCityAssociation[]
  legislationDetail   RplLegislationDetail?
  scoreChangeEvents   RplScoreChangeEvent[]
  annotations         RplAnalystAnnotation[]

  @@index([docType])
  @@index([momentumDirection])
  @@index([significance])
  @@index([publishedDate])
  @@index([isActive])
}

model RplDocumentFactorMapping {
  id                  String   @id @default(cuid())
  documentId          String
  document            RplDocument @relation(fields: [documentId], references: [id])
  factorCode          String   @db.VarChar(5)     // OPR | LEG | VRT | REG | PLT | ZON | MKT
  mappingType         String                     // PRIMARY | SECONDARY
  scoreDeltaEstimate  Int?     @db.SmallInt        // Estimated point impact (negative = decrease)
  mappingRationale    String?  @db.Text
  createdAt           DateTime @default(now())

  @@index([documentId])
  @@index([factorCode])
}

model RplDocumentCityAssociation {
  id                  String   @id @default(cuid())
  documentId          String
  document            RplDocument @relation(fields: [documentId], references: [id])
  cityId              String                     // References market/city ID
  associationType     String                     // DIRECTLY_NAMES | STATE_APPLIES | METRO_RELEVANT | NATIONAL
  scoringWeight       Decimal  @db.Decimal(3, 2)  // 0-1 applied to score_delta_estimate
  analystNote         String?  @db.Text
  createdAt           DateTime @default(now())

  @@index([documentId])
  @@index([cityId])
  @@unique([documentId, cityId])
}

model RplLegislationDetail {
  id                  String   @id @default(cuid())
  documentId          String   @unique
  document            RplDocument @relation(fields: [documentId], references: [id])
  jurisdiction        String   @db.Char(2)        // State code or "US"
  billNumber          String   @db.VarChar(30)     // "SB 2627", "HR 3935"
  chamber             String                     // SENATE | HOUSE | JOINT
  session             String   @db.VarChar(50)     // "89th Regular Session"
  currentStage        String                     // INTRODUCED | IN_COMMITTEE | PASSED_CHAMBER | ENROLLED | ENACTED | VETOED | DEAD
  sponsors            String[] @default([])
  lastActionDate      DateTime? @db.Date
  lastActionText      String?  @db.Text
  enrolledDate        DateTime? @db.Date
  enactedDate         DateTime? @db.Date
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([jurisdiction])
  @@index([currentStage])
  @@index([jurisdiction, currentStage])
}

model RplScoreChangeEvent {
  id                  String   @id @default(cuid())
  documentId          String
  document            RplDocument @relation(fields: [documentId], references: [id])
  cityId              String
  factorCode          String   @db.VarChar(5)
  scoreBefore         Decimal  @db.Decimal(5, 2)
  scoreAfter          Decimal  @db.Decimal(5, 2)
  delta               Decimal  @db.Decimal(5, 2)
  methodologyVersion  String
  appliedAt           DateTime @default(now())

  @@index([documentId])
  @@index([cityId, factorCode])
  @@index([appliedAt])
}

// ═══════════════════════════════════════════════════════════
// FPIS — Federal Programs Intelligence Store (Container 5)
// Dual consumer: Gap Analysis (subscriber-facing) and VDG
// Grant Tracker (internal). Every program mapped to factors
// it improves + markets it's relevant to.
// ═══════════════════════════════════════════════════════════

model FpisProgram {
  id                String   @id @default(cuid())
  code              String   @unique @db.VarChar(20) // DOT-RAISE, FAA-BEYOND, etc.
  name              String   @db.VarChar(200)
  agency            String   @db.VarChar(100)       // DOT, FAA, DoD/AFWERX, NASA, EDA, etc.
  awardRangeMin     Decimal? @db.Decimal(15, 2)     // Min award in USD
  awardRangeMax     Decimal? @db.Decimal(15, 2)     // Max award in USD
  cycle             String   @db.VarChar(50)        // Annual, Rolling, Discretionary, etc.
  programType       String   @db.VarChar(30)        // GRANT | SBIR | STTR | PILOT | PARTNERSHIP | CONTRACT
  description       String   @db.Text
  eligibility       String   @db.Text
  gapAnalysisRole   String   @db.Text               // How Gap Analysis surfaces this program
  vdgRelevance      String?  @db.Text               // Internal VDG grant strategy notes
  vdgPriority       String?  @db.VarChar(10)        // HIGHEST | HIGH | MEDIUM | LOW
  sbirEligible      Boolean  @default(false)        // Phase III pathway available
  isActive          Boolean  @default(true)
  websiteUrl        String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  factorImpacts     FpisProgramFactorImpact[]
  awards            FpisProgramAward[]
  applicationWindows FpisApplicationWindow[]
  vdgTrackerEntries FpisVdgGrantTracker[]

  @@index([agency])
  @@index([programType])
  @@index([isActive])
}

model FpisProgramFactorImpact {
  id               String   @id @default(cuid())
  programId        String
  program          FpisProgram @relation(fields: [programId], references: [id])
  factorCode       String   @db.VarChar(5)         // FKB factor code (PLT, VRT, REG, etc.)
  pointsOnAward    Int      @db.SmallInt            // Score impact when awarded
  impactNote       String?  @db.Text               // Context for the point impact
  createdAt        DateTime @default(now())

  @@index([programId])
  @@index([factorCode])
}

model FpisProgramAward {
  id               String   @id @default(cuid())
  programId        String
  program          FpisProgram @relation(fields: [programId], references: [id])
  cityId           String?                         // Market that received the award
  awardee          String   @db.VarChar(200)       // Organization name
  awardAmount      Decimal? @db.Decimal(15, 2)
  awardDate        DateTime @db.Date
  projectTitle     String?  @db.VarChar(500)
  sourceUrl        String?  @db.Text               // USASpending.gov link or press release
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([programId])
  @@index([cityId])
  @@index([awardDate])
}

model FpisApplicationWindow {
  id               String   @id @default(cuid())
  programId        String
  program          FpisProgram @relation(fields: [programId], references: [id])
  fiscalYear       String   @db.VarChar(10)        // FY2026, FY2027
  openDate         DateTime? @db.Date
  closeDate        DateTime? @db.Date
  nofoUrl          String?  @db.Text               // Notice of Funding Opportunity link
  status           String   @db.VarChar(20)        // UPCOMING | OPEN | CLOSED | CANCELLED
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([programId])
  @@index([status])
}

model FpisVdgGrantTracker {
  id               String   @id @default(cuid())
  programId        String
  program          FpisProgram @relation(fields: [programId], references: [id])
  applicationName  String   @db.VarChar(200)       // "SC Launch", "AFWERX Phase I", etc.
  status           String   @db.VarChar(20)        // IDENTIFIED | DRAFTING | SUBMITTED | UNDER_REVIEW | AWARDED | DECLINED
  targetAmount     Decimal? @db.Decimal(15, 2)
  submittedDate    DateTime? @db.Date
  decisionDate     DateTime? @db.Date
  outcome          String?  @db.VarChar(20)        // AWARDED | DECLINED | WITHDRAWN
  nextAction       String?  @db.Text
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([programId])
  @@index([status])
}

model RplAnalystAnnotation {
  id                  String   @id @default(cuid())
  documentId          String
  document            RplDocument @relation(fields: [documentId], references: [id])
  annotationType      String                     // CONTEXT | CORRECTION | PREDICTION | LINK
  content             String   @db.Text
  analystName         String
  createdAt           DateTime @default(now())

  @@index([documentId])
}

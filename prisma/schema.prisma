datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Auth.js required models ─────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  watchlist     Watchlist?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── App models ──────────────────────────────────────────────

model Subscription {
  id          String   @id @default(cuid())
  userId      String
  cityIds     String[]
  changeTypes String[]
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  cityIds   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoreSnapshot {
  id         String   @id @default(cuid())
  cityId     String
  score      Int
  breakdown  Json
  capturedAt DateTime @default(now())

  @@index([cityId, capturedAt])
}

model ScoringOverride {
  id             String    @id @default(cuid())
  cityId         String
  field          String    // scoring input name (e.g. "hasStateLegislation")
  value          Json      // the override value (e.g. true)
  reason         String
  sourceRecordId String?   // links to IngestedRecord.id
  sourceUrl      String?
  confidence     String    // "high" | "medium" | "needs_review"
  appliedAt      DateTime? // set when auto-applied
  supersededAt   DateTime? // set when a newer override replaces this one
  createdAt      DateTime  @default(now())

  @@index([cityId, field])
}

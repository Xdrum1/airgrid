datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Auth.js required models ─────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  firstName             String?
  lastName              String?
  organization          String?
  jobTitle              String?
  buyerType             String?   // infra-developer|operator|municipality|heliport-owner|insurance|federal|other
  referralSource        String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  stripeCustomerId      String?   @unique
  tier                  String    @default("free") // free|pro|institutional|enterprise|grandfathered
  role                  String?   // legacy — kept for existing data
  accounts              Account[]
  sessions              Session[]
  subscriptions         Subscription[]
  billingSubscriptions  BillingSubscription[]
  watchlist             Watchlist?
  events                UserEvent[]
  apiKeys               ApiKey[]
  loginEvents           LoginEvent[]
  newsletterOptOut      Boolean   @default(false)
  lastActiveAt          DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── App models ──────────────────────────────────────────────

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  cityIds      String[]
  corridorIds  String[] @default([])
  changeTypes  String[]
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  cityIds   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoreSnapshot {
  id                String   @id @default(cuid())
  cityId            String
  score             Int
  breakdown         Json
  tier              String?  // "HIGH" | "MODERATE" | "EARLY" | "NASCENT"
  triggeringEventId String?  // links to ChangelogEntry.id
  filingIngestedAt  DateTime? // when the triggering filing was first ingested
  capturedAt        DateTime @default(now())

  @@index([cityId, capturedAt])
}

model ClassificationResult {
  id             String   @id @default(cuid())
  recordId       String   // IngestedRecord.id
  eventType      String   // from the event_type vocabulary
  factorsJson    Json     // full factors_affected array from Claude
  affectedCities String[] // city IDs identified
  confidence     String   // "high" | "medium" | "needs_review"
  rawResponse    Json     // full Claude API response for debugging
  modelUsed      String   // e.g. "claude-haiku-4-5-20251001"
  promptVersion  String   // version string for prompt tracking
  createdAt      DateTime @default(now())

  @@index([recordId])
  @@index([eventType])
  @@index([confidence])
}

model ChangelogEntry {
  id                String   @id @default(cuid())
  changeType        String   // "new_filing" | "status_change" | "new_law" | "faa_update" | "score_change"
  relatedEntityType String   // "city" | "vertiport" | "operator" | "corridor" | "filing"
  relatedEntityId   String
  summary           String
  sourceUrl         String?
  timestamp         DateTime @default(now())

  @@index([timestamp])
  @@index([changeType])
}

model Corridor {
  id                    String    @id // e.g. "cor_lax_dtla"
  name                  String
  status                String    // "proposed" | "authorized" | "active" | "suspended"
  cityId                String
  operatorId            String?
  startPointLat         Float
  startPointLng         Float
  startPointLabel       String
  endPointLat           Float
  endPointLng           Float
  endPointLabel         String
  waypoints             Json?     // Array of { lat, lng }
  distanceKm            Float
  estimatedFlightMinutes Int
  maxAltitudeFt         Int
  altitudeMinFt         Int?
  faaAuthNumber         String?
  effectiveDate         String?
  expirationDate        String?
  clearedOperators      String[]
  notes                 String?
  sourceUrl             String?
  lastUpdated           DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  statusHistory CorridorStatusHistory[]

  @@index([cityId])
  @@index([status])
  @@index([operatorId])
}

model CorridorStatusHistory {
  id          String    @id @default(cuid())
  corridorId  String
  fromStatus  String?
  toStatus    String
  reason      String?
  sourceUrl   String?
  changedAt   DateTime  @default(now())

  corridor    Corridor  @relation(fields: [corridorId], references: [id], onDelete: Cascade)

  @@index([corridorId, changedAt])
}

model UserEvent {
  id         String   @id @default(cuid())
  userId     String
  event      String   // "page_view" | "city_detail" | "corridor_click" | "tab_switch" | "report_download" | "operator_click"
  entityType String?  // "city" | "corridor" | "operator" | "page" | "tab" | "report"
  entityId   String?  // e.g. "los_angeles", "cor_mia_fll", "/methodology"
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([event])
  @@index([entityType, entityId])
}

model ScoringOverride {
  id             String    @id @default(cuid())
  cityId         String
  field          String    // scoring input name (e.g. "hasStateLegislation")
  value          Json      // the override value (e.g. true)
  reason         String
  sourceRecordId String?   // links to IngestedRecord.id
  sourceUrl      String?
  confidence     String    // "high" | "medium" | "needs_review"
  origin         String    @default("classifier") // "classifier" | "analyst" | "admin" — who/what created this override
  appliedAt      DateTime? // set when auto-applied
  supersededAt   DateTime? // set when a newer override replaces this one
  createdAt      DateTime  @default(now())

  @@index([cityId, field])
  @@index([origin])
}

model AutoReviewResult {
  id              String   @id @default(cuid())
  overrideId      String
  decision        String   // "approve" | "reject" | "skip"
  confidence      Float
  assignedCityId  String?  // city assigned for __unresolved__ overrides
  reasoning       String
  applied         Boolean  // whether the decision was actually applied
  dryRun          Boolean  @default(false)
  modelUsed       String
  sourceContent   String?  // truncated source text if fetched
  // Feedback loop — compare AI decision to human decision
  humanOutcome    String?  // correct | false_positive | false_negative
  humanOutcomeAt  DateTime?
  createdAt       DateTime @default(now())

  @@index([overrideId])
  @@index([decision])
  @@index([createdAt])
  @@index([humanOutcome])
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  role      String?
  tier      String   // "pro" | "institutional" | "enterprise"
  message   String?
  status    String   @default("new") // new | contacted | qualified | converted | closed
  notes     String?  // admin notes for follow-up tracking
  source    String?  // ref param from contact form (e.g. "breakdown", "alerts", "api")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([tier])
  @@index([email])
  @@index([status])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  tier       String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BillingSubscription {
  id                    String    @id @default(cuid())
  userId                String
  stripeCustomerId      String
  stripeSubscriptionId  String    @unique
  stripePriceId         String
  tier                  String    // pro|institutional|enterprise
  status                String    // active|past_due|canceled|trialing|unpaid
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean   @default(false)
  canceledAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([status])
}

model IngestedRecord {
  id          String   @id // e.g. "federal_register_FR2023..."
  source      String   // "federal_register" | "legiscan" | "sec_edgar" | "operator_news"
  sourceId    String
  title       String
  summary     String
  status      String
  date        String
  url         String
  state       String?
  raw         Json
  ingestedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source])
}

model IngestionRun {
  id              String   @id @default(cuid())
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  newRecords      Int      @default(0)
  updatedRecords  Int      @default(0)
  unchangedCount  Int      @default(0)
  totalRecords    Int      @default(0)
  sources         String[] // ["federal_register", "legiscan", ...]
  overridesCreated Int     @default(0)
  overridesApplied Int     @default(0)
  scoreChanges    Int      @default(0)
  error           String?  // null = success, else error message
  alertSent       Boolean  @default(false)

  @@index([startedAt])
}

// ── Market Watch (ratings agency layer) ─────────────────────

model MarketWatch {
  id          String    @id @default(cuid())
  cityId      String    @unique
  watchStatus String    @default("STABLE") // STABLE | POSITIVE_WATCH | NEGATIVE_WATCH | DEVELOPING
  outlook     String    @default("STABLE") // IMPROVING | STABLE | DETERIORATING
  analystNote String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  history MarketWatchHistory[]

  @@index([watchStatus])
  @@index([published])
}

model MarketWatchHistory {
  id              String    @id @default(cuid())
  marketWatchId   String
  cityId          String
  fromWatchStatus String?
  toWatchStatus   String
  fromOutlook     String?
  toOutlook       String
  analystNote     String?
  reason          String
  source          String    @default("admin") // "admin" | "ai_suggested"
  suggestedBy     String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())

  marketWatch MarketWatch @relation(fields: [marketWatchId], references: [id], onDelete: Cascade)

  @@index([cityId, createdAt])
  @@index([marketWatchId])
}

model MarketWatchSuggestion {
  id               String   @id @default(cuid())
  cityId           String
  suggestedStatus  String
  suggestedOutlook String
  reasoning        String
  confidence       Float
  signalCount      Int
  status           String   @default("pending") // pending | accepted | dismissed
  createdAt        DateTime @default(now())

  @@index([cityId])
  @@index([status])
}

// ── Automated Watch List (pipeline-driven) ──────────────

model WatchListEntry {
  id               String    @id @default(cuid())
  cityId           String
  triggerType       String    // LEGISLATION | PIPELINE_OVERRIDE | ELEVATED_ACTIVITY
  triggerDetail     String    // human-readable description
  currentScore      Int       // score at time of trigger
  triggeredAt       DateTime  @default(now())
  resolvedAt        DateTime? // null if still active
  resolutionReason  String?   // SCORE_CHANGED | SIGNAL_RESOLVED | MANUAL_REMOVE

  @@index([cityId])
  @@index([triggerType])
  @@index([resolvedAt])
}

// ── Intel Feed ──────────────────────────────────────────

model FeedItem {
  id                     String    @id @default(cuid())
  slug                   String?   @unique
  title                  String
  summary                String    // 1-2 editorial sentences
  sourceUrl              String?
  category               String    // "Regulatory" | "Infrastructure" | "Operator" | "Legislative"
  cityIds                String[]  // tracked market city IDs
  scoreImpact            Boolean   @default(false)
  status                 String    @default("draft") // "draft" | "published" | "archived"
  promotedBy             String?   // "admin" | "auto"
  sourceRecordId         String?   // optional link to IngestedRecord.id
  classificationResultId String?   // optional link to ClassificationResult.id
  publishedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([category])
}

model MarketLead {
  id              String    @id @default(cuid())
  city            String    // e.g. "Columbus"
  state           String    // e.g. "OH"
  country         String    @default("US")
  source          String    // who tipped it — e.g. "Mike", "Rex", "SEC filing", "news"
  signal          String    // what they said / what was observed
  status          String    @default("new") // new | researching | verified | added | dismissed
  priority        String    @default("normal") // low | normal | high
  researchNotes   String?   // running notes on 7-factor research
  factorSnapshot  Json?     // partial scoring assessment: { hasStateLegislation: true, ... }
  addedAsCityId   String?   // set when graduated to live market (links to city id in seed)
  dismissedReason String?   // why it was dismissed
  signalCount     Int       @default(1)      // number of distinct signals accumulated
  lastSignalAt    DateTime? // when the most recent signal was detected
  signalSources   Json?     // array of { source, url, date, summary } for audit trail
  aiRecommendation String?  // ADD | WATCH | DISMISS | ENRICH
  aiReasoning     String?   @db.Text // Claude's reasoning for the recommendation
  aiConfidence    String?   // high | medium | low
  aiEvaluatedAt   DateTime? // when AI last evaluated this lead
  // Feedback loop — compare AI recommendation to actual human decision
  aiOutcome       String?   // correct | false_positive | false_negative | pending
  aiOutcomeAt     DateTime? // when outcome was recorded (at approval/dismissal)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([city, state, country])
  @@index([status])
  @@index([priority])
}

// ── FAA Heliport Data (NASR 5010) ────────────────────────

model Heliport {
  id              String   @id // FAA Location Identifier (e.g. "0LA1")
  facilityName    String
  city            String
  state           String
  county          String?
  ownershipType   String   // "PU" (public) | "PR" (private) | "MA" (Air Force) | "MN" (Navy) | "MR" (Army)
  useType         String   // "PU" (public use) | "PR" (private use)
  lat             Float
  lng             Float
  elevation       Float?   // feet MSL
  statusCode      String   // "O" (operational) | "CI" (closed indefinitely) | "CP" (closed permanently)
  certTypeDate    String?  // certification type
  airportOfEntry  String?
  federalAgreement String?
  airspaceAnalysis String?
  basedAircraft   Int?
  annualOps       Int?
  cityId          String?  // mapped AirIndex market ID (null if not in tracked metro)
  padLengthFt     Int?     // from APT_RWY.csv RWY_LEN — pad dimension in feet
  padWidthFt      Int?     // from APT_RWY.csv RWY_WIDTH — pad dimension in feet
  surfaceType     String?  // from APT_RWY.csv SURFACE_TYPE_CODE — CONC, ASPH, TURF, etc.
  surfaceCondition String? // from APT_RWY.csv COND — GOOD, FAIR, POOR
  activationDate   String?  // from APT_BASE.csv ACTIVATION_DATE — YYYY/MM format
  lastInfoResponse String?  // from APT_BASE.csv LAST_INFO_RESPONSE — last owner update
  lastInspection   String?  // from APT_BASE.csv LAST_INSPECTION
  positionSrcDate  String?  // from APT_BASE.csv POSITION_SRC_DATE
  elevationSrcDate String?  // from APT_BASE.csv ELEVATION_SRC_DATE
  ingestedAt       DateTime @default(now())

  @@index([cityId])
  @@index([state])
  @@index([ownershipType])
  @@index([statusCode])
}

// ── Event-Driven Signal Layer (Phase 2) ─────────────────

model SignalEvent {
  id         String    @id @default(cuid())
  source     String    // "federal_register" | "legiscan" | "sec_edgar" | "operator_news"
  cityId     String
  eventType  String    // regulatory_filing | legislative_activity | operator_announcement | faa_update
  title      String
  sourceUrl  String?
  confidence String    // "high" | "medium" | "needs_review"
  rawRecord  Json      // original record data for audit
  detectedAt DateTime  @default(now())
  notifiedAt DateTime? // when Pro+ subscribers were notified (null = pending)

  @@index([cityId, detectedAt])
  @@index([source])
  @@index([eventType])
  @@index([confidence, detectedAt])
}

// ── Emerging Markets Stealth Pipeline ────────────────────

model EmergingMarketSignal {
  id           String   @id @default(cuid())
  marketName   String   // e.g. "Nuclear SMR", "Commercial Drone", "Hydrogen Fueling"
  sourceId     String   // unique ID from source API
  title        String
  url          String
  source       String   // "doe_arpa_e" | "clinicaltrials_gov" | "nrc_adams" | ...
  relevant     Boolean
  signalType   String   // regulatory_filing | legislative_activity | grant_award | patent_filing | investment_round | research_publication | other
  momentum     String   // positive | negative | neutral
  raw          Json     // full API response for audit
  classifiedAt DateTime
  ingestedAt   DateTime @default(now())

  // Classification audit trail — same discipline as AirIndex ClassificationResult
  promptVersion     String?  // e.g. "emerging-v1"
  modelUsed         String?  // e.g. "claude-haiku-4-5-20251001"
  confidence        String?  // "high" | "medium" | "low" — classifier self-assessed confidence
  rawClassification Json?    // full Claude API response for reproducibility audit

  @@unique([source, sourceId])
  @@index([marketName])
  @@index([source])
  @@index([signalType])
  @@index([relevant, ingestedAt])
}

// Aggregated city/state leads for emerging markets — mirror of MarketLead
// but scoped to stealth domains (Drone, Hydrogen, AV, SMR, etc.)
model EmergingMarketLead {
  id              String   @id @default(cuid())
  domain          String   // "Commercial Drone" | "Hydrogen Fueling" | "Autonomous Vehicle" | "Nuclear SMR" | ...
  city            String
  state           String
  country         String   @default("US")
  signalCount     Int      @default(1)
  lastSignalAt    DateTime?
  priority        String   @default("low") // low | normal | high
  status          String   @default("new") // new | researching | watching | archived
  signalSources   Json?    // array of { source, url, date, summary, signalType }
  researchNotes   String?  @db.Text
  // AI evaluation (same pattern as MarketLead)
  aiRecommendation String? // WATCH | ELEVATE | ARCHIVE | ENRICH
  aiReasoning     String?  @db.Text
  aiConfidence    String?
  aiEvaluatedAt   DateTime?
  aiOutcome       String?
  aiOutcomeAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([domain, city, state, country])
  @@index([domain])
  @@index([status])
  @@index([priority])
}

// ── Login Device Tracking ────────────────────────────────

model LoginEvent {
  id              String    @id @default(cuid())
  userId          String
  ip              String
  userAgent       String?
  fingerprintHash String    // SHA-256 of (userAgent + IP /24 subnet)
  deviceType      String?   // "Desktop" | "Mobile" | "Tablet" | "Unknown"
  browser         String?   // "Chrome 120" | "Safari 17" etc.
  os              String?   // "macOS 14" | "Windows 11" etc.
  isNewDevice     Boolean   @default(false)
  notifiedAt      DateTime? // when notification email was sent
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, fingerprintHash])
  @@index([userId, createdAt])
}

// ── Newsletter Tracking ──────────────────────────────────

model NewsletterEvent {
  id        String   @id @default(cuid())
  series    String   @default("newsletter") // "newsletter" | "pulse" | "monday"
  email     String
  issue     Int
  event     String   // "open" | "click"
  url       String?  // destination URL for click events
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([email, issue])
  @@index([issue, event])
  @@index([series, issue])
  @@index([createdAt])
}

model PulseSubscriber {
  id           String   @id @default(cuid())
  name         String
  organization String
  email        String   @unique
  source       String   @default("homepage") // "homepage" | "report" | "heliport-audit"
  subscribedAt DateTime @default(now())
  unsubscribedAt DateTime?

  @@index([source])
  @@index([subscribedAt])
}

// ═══════════════════════════════════════════════════════════
// MCS — Market Context Store (Foundation)
// Canonical market registry. Every container references
// Market.id as the stable city identifier.
// ═══════════════════════════════════════════════════════════

model Market {
  id            String   @id                     // Matches seed.ts city IDs (e.g. "los_angeles")
  city          String                           // "Los Angeles"
  state         String   @db.Char(2)             // "CA"
  metro         String?                          // "Greater Los Angeles"
  country       String   @default("US") @db.Char(2)
  lat           Decimal  @db.Decimal(9, 6)
  lng           Decimal  @db.Decimal(9, 6)
  isActive      Boolean  @default(true)
  addedAt       DateTime @default(now())
  updatedAt     DateTime @updatedAt

  factorScores  FkbFactorScore[]
  ordinanceAudit OrdinanceAudit?

  @@index([state])
  @@index([isActive])
}

// ── Municipality Ordinance Audit Data ────────────────────
// Manual-seed table: 5 compliance questions per market.
// Populated by Alan, imported by dev. Updated as ordinances change.

model OrdinanceAudit {
  id                    String   @id @default(cuid())
  marketId              String   @unique
  market                Market   @relation(fields: [marketId], references: [id])
  faaTerminology        String   @default("unknown") // yes | no | partial | unknown
  faaTerminologyNote    String?  @db.Text
  zoningOrdinance       String   @default("unknown") // yes | no | partial | unknown
  zoningOrdinanceNote   String?  @db.Text
  airspaceDetermination String   @default("unknown") // yes | no | partial | unknown
  airspaceDeterminationNote String? @db.Text
  nfpa418Referenced     String   @default("unknown") // yes | no | partial | unknown
  nfpa418ReferencedNote String?  @db.Text
  stateAdoptedAC        String   @default("unknown") // yes | no | partial | unknown
  stateAdoptedACNote    String?  @db.Text
  lastAuditedAt         DateTime? @db.Date
  auditedBy             String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════
// MCS — Market Context Store (Container 2)
// Peer comparison, state context, and regional clusters.
// Enables "what did Dallas do?" cross-market queries and
// buyer-specific peer tables in briefing reports.
// ═══════════════════════════════════════════════════════════

model McsStateContext {
  id                    String   @id @default(cuid())
  stateCode             String   @unique @db.Char(2)
  stateName             String   @db.VarChar(50)
  legislationStatus     String   @db.VarChar(20)    // enacted | actively_moving | none
  enforcementPosture    String   @db.VarChar(20)    // strong | moderate | limited | none
  enforcementNote       String?  @db.Text           // Rex-sourced context on state enforcement
  dotAamEngagement      String   @db.VarChar(20)    // active | emerging | none
  dotAamNote            String?  @db.Text
  aamOfficeEstablished  Boolean  @default(false)
  keyLegislation        String?  @db.Text           // Primary bill(s) — e.g. "TX HB 1735", "CA SB 944"
  regulatoryBurdenLevel String?  @db.VarChar(20)    // low | moderate | high | severe — process friction for establishing infrastructure (Rex proposal Apr 2026; distinct from posture stance)
  regulatoryBurdenNote  String?  @db.Text           // Specific statute/rule cited + why it's burdensome
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model McsRegionalCluster {
  id                String   @id @default(cuid())
  name              String   @unique @db.VarChar(100) // "SoCal Corridor", "Texas Triangle", etc.
  description       String?  @db.Text
  marketIds         String[] @default([])             // Market IDs in this cluster
  corridorRelevance String?  @db.Text                 // How cluster relates to corridor planning
  createdAt         DateTime @default(now())
}

model McsPeerGroup {
  id                String   @id @default(cuid())
  marketId          String                            // The market this peer group is for
  peerMarketIds     String[] @default([])             // Markets considered peers
  groupingBasis     String   @db.VarChar(30)          // SAME_TIER | SAME_STATE | SIMILAR_PROFILE | REGIONAL
  notes             String?  @db.Text
  createdAt         DateTime @default(now())

  @@unique([marketId, groupingBasis])
  @@index([marketId])
}

// ═══════════════════════════════════════════════════════════
// FKB — Factor Knowledge Base (Container 1)
// Authoritative source of truth for scoring factors, weights,
// data sources, per-market factor scores, and analyst overrides.
// Hard rule: no deletes. Retire factors, deprecate sources,
// log overrides — never DELETE.
// ═══════════════════════════════════════════════════════════

model FkbFactor {
  id               String   @id @default(cuid())
  code             String   @unique              // OPR, LEG, VRT, REG, PLT, ZON, MKT
  name             String                        // "Operator Presence"
  description      String   @db.Text             // Canonical definition
  scoringTier      String                        // PRIMARY | DERIVED | BINARY
  introducedIn     String                        // Methodology version (e.g. "v1.0")
  retired          Boolean  @default(false)
  retiredIn        String?                       // Version retired (e.g. "v1.3" for LAANC)
  retirementReason String?  @db.Text
  sortOrder        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  weights          FkbFactorWeight[]
  sources          FkbFactorSource[]
  scores           FkbFactorScore[]
}

model FkbFactorWeight {
  id               String   @id @default(cuid())
  factorId         String
  factor           FkbFactor @relation(fields: [factorId], references: [id])
  methodologyVersion String                     // "v1.3"
  weightPct        Decimal  @db.Decimal(5, 2)    // 0-100 weight
  effectiveFrom    DateTime @db.Date
  effectiveTo      DateTime? @db.Date            // NULL = currently active
  changeRationale  String   @db.Text
  approvedBy       String                        // Name/title of approver
  createdAt        DateTime @default(now())

  @@index([factorId, methodologyVersion])
  @@index([effectiveFrom])
}

model FkbFactorSource {
  id               String   @id @default(cuid())
  factorId         String
  factor           FkbFactor @relation(fields: [factorId], references: [id])
  sourceName       String                        // "Federal Register API"
  sourceType       String                        // API | RSS | SCRAPE | MANUAL | UPLOAD
  baseUrl          String?  @db.Text
  apiEndpoint      String?  @db.Text
  reliabilityScore Int      @db.SmallInt          // 1-5: 5=federal official, 1=press/social
  updateFrequency  String                        // DAILY | WEEKLY | MONTHLY | ON_EVENT
  lastVerified     DateTime? @db.Date
  isActive         Boolean  @default(true)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([factorId])
  @@index([isActive])
}

model FkbFactorScore {
  id                  String   @id @default(cuid())
  factorId            String
  factor              FkbFactor @relation(fields: [factorId], references: [id])
  marketId            String
  market              Market   @relation(fields: [marketId], references: [id])
  score               Decimal  @db.Decimal(5, 2)  // Raw factor score
  scoreNormalized     Decimal  @db.Decimal(5, 2)  // Scaled to 0-100 contribution range
  methodologyVersion  String
  confidence          String                     // HIGH | MEDIUM | LOW
  confidenceReasons   Json?                      // [{reason, impact}]
  signalCount         Int      @default(0)
  hasOverride         Boolean  @default(false)
  scoredAt            DateTime @default(now())

  overrides           FkbScoreOverride[]

  @@unique([factorId, marketId, methodologyVersion])
  @@index([marketId])
  @@index([confidence])
}

model FkbScoreOverride {
  id                  String   @id @default(cuid())
  factorScoreId       String
  factorScore         FkbFactorScore @relation(fields: [factorScoreId], references: [id])
  originalScore       Decimal  @db.Decimal(5, 2)
  overrideScore       Decimal  @db.Decimal(5, 2)
  overrideReason      String   @db.Text
  evidenceUrl         String?  @db.Text
  overrideType        String                     // UPWARD | DOWNWARD
  overrideConfidence  String                     // HIGH | MEDIUM
  analystName         String
  reviewedBy          String?                    // Second reviewer for magnitude >5
  expiresAt           DateTime? @db.Date          // Auto-flag for re-evaluation
  createdAt           DateTime @default(now())

  @@index([factorScoreId])
}

model FkbMethodologyVersion {
  id               String   @id @default(cuid())
  version          String   @unique              // "v1.0", "v1.3", etc.
  effectiveDate    DateTime @db.Date
  summary          String   @db.Text             // Human-readable changelog
  factorsAdded     String[] @default([])          // Factor codes added
  factorsRetired   String[] @default([])          // Factor codes retired
  weightsChanged   Json?                         // [{factorCode, oldWeight, newWeight}]
  approvedBy       String
  createdAt        DateTime @default(now())
}

// ═══════════════════════════════════════════════════════════
// OID — Operator Intelligence Database (Container 3)
// Structured intelligence about every eVTOL/UAM operator.
// Feeds OPR factor scoring. Standalone API product for
// Institutional/Enterprise tiers.
// Hard rule: no deletes. Operators marked is_active=FALSE.
// Market presence records for EXITED retained as history.
// ═══════════════════════════════════════════════════════════

model OidOperator {
  id                String   @id @default(cuid())
  name              String   @db.VarChar(200)      // Legal/operating name
  shortName         String   @db.VarChar(50)       // Display name (e.g. "Joby")
  ticker            String?  @db.VarChar(10)       // Stock ticker if public
  cik               String?  @db.VarChar(20)       // SEC CIK number
  entityType        String   @db.VarChar(30)       // MANUFACTURER | OPERATOR | OPERATOR_MANUFACTURER | INFRASTRUCTURE
  vehicleType       String?  @db.VarChar(50)       // eVTOL | eSTOL | VTOL | HYBRID
  hqCity            String?  @db.VarChar(100)
  hqCountry         String   @default("US") @db.Char(2)
  foundedYear       Int?     @db.SmallInt
  website           String?  @db.Text
  isActive          Boolean  @default(true)
  inactiveReason    String?  @db.Text              // Acquisition, bankruptcy, pivot
  acquiredBy        String?                        // Self-referential — OidOperator.id
  oprWeightMultiplier Decimal @default(1.0) @db.Decimal(3, 2) // Analyst-adjustable
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  marketPresence    OidOperatorMarketPresence[]
  events            OidOperatorEvent[]
  certifications    OidOperatorCertification[]
  financing         OidOperatorFinancing[]
  vertiportCommitments OidVertiportCommitment[]

  @@index([entityType])
  @@index([isActive])
}

model OidOperatorMarketPresence {
  id               String   @id @default(cuid())
  operatorId       String
  operator         OidOperator @relation(fields: [operatorId], references: [id])
  cityId           String                         // References Market.id
  deploymentStage  String   @db.VarChar(20)       // COMMERCIAL_OPS | CERTIFIED | TESTING | ANNOUNCED | WATCHLIST | EXITED
  stageScore       Int      @db.SmallInt           // 20 | 15 | 10 | 5 | 2 | 0
  stageSetAt       DateTime @db.Date
  stageSetBy       String   @db.VarChar(20)       // PIPELINE | ANALYST
  evidenceEventId  String?                        // References OidOperatorEvent.id
  confidence       String   @db.VarChar(10)       // HIGH | MEDIUM | LOW
  notes            String?  @db.Text
  routeAnnounced   Boolean  @default(false)
  vertiportCommitted Boolean @default(false)
  isActive         Boolean  @default(true)        // FALSE if operator exited market
  lastSignalAt     DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([operatorId, cityId])
  @@index([cityId])
  @@index([deploymentStage])
  @@index([isActive])
}

model OidOperatorEvent {
  id                    String   @id @default(cuid())
  operatorId            String
  operator              OidOperator @relation(fields: [operatorId], references: [id])
  cityId                String?                   // NULL for company-wide events
  eventType             String   @db.VarChar(30)   // 20-type taxonomy
  eventDate             DateTime @db.Date
  headline              String   @db.VarChar(300)
  sourceName            String   @db.VarChar(100)
  sourceUrl             String?  @db.Text
  sourceReliability     Int      @db.SmallInt       // 1-5
  stageImplication      String?  @db.VarChar(20)   // Which deployment stage this implies
  stageImplicationConfidence String? @db.VarChar(10) // HIGH | MEDIUM | LOW
  rawSignalId           String?                    // Pipeline signal link
  isVerified            Boolean  @default(false)
  verifiedBy            String?  @db.VarChar(100)
  ingestedAt            DateTime @default(now())

  @@index([operatorId])
  @@index([cityId])
  @@index([eventType])
  @@index([eventDate])
}

model OidOperatorCertification {
  id               String   @id @default(cuid())
  operatorId       String
  operator         OidOperator @relation(fields: [operatorId], references: [id])
  certType         String   @db.VarChar(30)       // FAA_PART135 | FAA_TYPE_CERT | FAA_EXPERIMENTAL | FAA_ATCO | FAA_BEYOND | OTHER
  certNumber       String?  @db.VarChar(100)
  issuingAuthority String   @db.VarChar(100)
  cityId           String?                        // Market-specific cert, NULL for national
  issuedDate       DateTime? @db.Date
  effectiveDate    DateTime? @db.Date
  expiryDate       DateTime? @db.Date
  isActive         Boolean  @default(true)
  sourceUrl        String?  @db.Text
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([operatorId])
  @@index([certType])
}

model OidOperatorFinancing {
  id               String   @id @default(cuid())
  operatorId       String
  operator         OidOperator @relation(fields: [operatorId], references: [id])
  roundType        String   @db.VarChar(30)       // SEED | SERIES_A | SERIES_B | SERIES_C | DEBT | SPAC | IPO | GRANT | STRATEGIC
  amountUsd        Decimal? @db.Decimal(15, 2)
  amountDisclosed  Boolean  @default(true)
  announcedDate    DateTime @db.Date
  closedDate       DateTime? @db.Date
  leadInvestor     String?  @db.VarChar(200)
  notableInvestors String[] @default([])
  totalRaisedToDate Decimal? @db.Decimal(15, 2)
  sourceName       String   @db.VarChar(100)
  sourceUrl        String?  @db.Text
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([operatorId])
  @@index([roundType])
  @@index([announcedDate])
}

model OidVertiportCommitment {
  id               String   @id @default(cuid())
  operatorId       String
  operator         OidOperator @relation(fields: [operatorId], references: [id])
  cityId           String                         // References Market.id
  commitmentType   String   @db.VarChar(30)       // GROUND_LEASE | MOU | LOI | PARTNERSHIP | OWNERSHIP
  siteName         String?  @db.VarChar(200)
  partnerName      String?  @db.VarChar(200)      // Airport authority, developer, etc.
  announcedDate    DateTime @db.Date
  sourceUrl        String?  @db.Text
  isActive         Boolean  @default(true)
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([operatorId])
  @@index([cityId])
}

// ═══════════════════════════════════════════════════════════
// RPL — Regulatory Precedent Library (Container 4)
// Structured repository of regulatory documents, legislative
// records, and administrative rulings. Evidence layer for
// REG + LEG scoring. Training corpus for Prediction Layer.
// Hard rule: nothing is ever deleted. Append-only.
// ═══════════════════════════════════════════════════════════

model RplDocument {
  id                  String   @id @default(cuid())
  docType             String                     // FEDERAL_RULE, STATE_BILL, etc. (15 types)
  title               String   @db.VarChar(500)
  shortTitle          String?  @db.VarChar(200)   // Human-readable for watch list
  issuingAuthority    String   @db.VarChar(100)   // "FAA", "LegiScan / Texas Legislature"
  documentNumber      String?  @db.VarChar(100)   // Docket, bill number, order number
  publishedDate       DateTime @db.Date
  effectiveDate       DateTime? @db.Date          // When enacted/effective
  momentumDirection   String   @db.Char(3)        // POS | NEG | NEU | MIX
  significance        String                     // HIGH | MEDIUM | LOW
  summary             String?  @db.Text           // AI-generated or analyst summary
  sourceUrl           String?  @db.Text
  storageKey          String?  @db.Text           // S3 key for full-text body
  storageFetchedAt    DateTime?
  rawSignalId         String?                    // Link to pipeline signal if originated there
  isActive            Boolean  @default(true)     // FALSE if withdrawn/superseded/vetoed
  supersededBy        String?                    // Self-referential FK
  ingestedAt          DateTime @default(now())
  updatedAt           DateTime @updatedAt

  factorMappings      RplDocumentFactorMapping[]
  cityAssociations    RplDocumentCityAssociation[]
  legislationDetail   RplLegislationDetail?
  scoreChangeEvents   RplScoreChangeEvent[]
  annotations         RplAnalystAnnotation[]

  @@index([docType])
  @@index([momentumDirection])
  @@index([significance])
  @@index([publishedDate])
  @@index([isActive])
}

model RplDocumentFactorMapping {
  id                  String   @id @default(cuid())
  documentId          String
  document            RplDocument @relation(fields: [documentId], references: [id])
  factorCode          String   @db.VarChar(5)     // OPR | LEG | VRT | REG | PLT | ZON | MKT
  mappingType         String                     // PRIMARY | SECONDARY
  scoreDeltaEstimate  Int?     @db.SmallInt        // Estimated point impact (negative = decrease)
  mappingRationale    String?  @db.Text
  createdAt           DateTime @default(now())

  @@index([documentId])
  @@index([factorCode])
}

model RplDocumentCityAssociation {
  id                  String   @id @default(cuid())
  documentId          String
  document            RplDocument @relation(fields: [documentId], references: [id])
  cityId              String                     // References market/city ID
  associationType     String                     // DIRECTLY_NAMES | STATE_APPLIES | METRO_RELEVANT | NATIONAL
  scoringWeight       Decimal  @db.Decimal(3, 2)  // 0-1 applied to score_delta_estimate
  analystNote         String?  @db.Text
  createdAt           DateTime @default(now())

  @@index([documentId])
  @@index([cityId])
  @@unique([documentId, cityId])
}

model RplLegislationDetail {
  id                  String   @id @default(cuid())
  documentId          String   @unique
  document            RplDocument @relation(fields: [documentId], references: [id])
  jurisdiction        String   @db.Char(2)        // State code or "US"
  billNumber          String   @db.VarChar(30)     // "SB 2627", "HR 3935"
  chamber             String                     // SENATE | HOUSE | JOINT
  session             String   @db.VarChar(50)     // "89th Regular Session"
  currentStage        String                     // INTRODUCED | IN_COMMITTEE | PASSED_CHAMBER | ENROLLED | ENACTED | VETOED | DEAD
  sponsors            String[] @default([])
  lastActionDate      DateTime? @db.Date
  lastActionText      String?  @db.Text
  enrolledDate        DateTime? @db.Date
  enactedDate         DateTime? @db.Date
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([jurisdiction])
  @@index([currentStage])
  @@index([jurisdiction, currentStage])
}

model RplScoreChangeEvent {
  id                  String   @id @default(cuid())
  documentId          String
  document            RplDocument @relation(fields: [documentId], references: [id])
  cityId              String
  factorCode          String   @db.VarChar(5)
  scoreBefore         Decimal  @db.Decimal(5, 2)
  scoreAfter          Decimal  @db.Decimal(5, 2)
  delta               Decimal  @db.Decimal(5, 2)
  methodologyVersion  String
  appliedAt           DateTime @default(now())

  @@index([documentId])
  @@index([cityId, factorCode])
  @@index([appliedAt])
}

// ═══════════════════════════════════════════════════════════
// FPIS — Federal Programs Intelligence Store (Container 5)
// Dual consumer: Gap Analysis (subscriber-facing) and VDG
// Grant Tracker (internal). Every program mapped to factors
// it improves + markets it's relevant to.
// ═══════════════════════════════════════════════════════════

model FpisProgram {
  id                String   @id @default(cuid())
  code              String   @unique @db.VarChar(20) // DOT-RAISE, FAA-BEYOND, etc.
  name              String   @db.VarChar(200)
  agency            String   @db.VarChar(100)       // DOT, FAA, DoD/AFWERX, NASA, EDA, etc.
  awardRangeMin     Decimal? @db.Decimal(15, 2)     // Min award in USD
  awardRangeMax     Decimal? @db.Decimal(15, 2)     // Max award in USD
  cycle             String   @db.VarChar(50)        // Annual, Rolling, Discretionary, etc.
  programType       String   @db.VarChar(30)        // GRANT | SBIR | STTR | PILOT | PARTNERSHIP | CONTRACT
  description       String   @db.Text
  eligibility       String   @db.Text
  gapAnalysisRole   String   @db.Text               // How Gap Analysis surfaces this program
  vdgRelevance      String?  @db.Text               // Internal VDG grant strategy notes
  vdgPriority       String?  @db.VarChar(10)        // HIGHEST | HIGH | MEDIUM | LOW
  sbirEligible      Boolean  @default(false)        // Phase III pathway available
  isActive          Boolean  @default(true)
  websiteUrl        String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  factorImpacts     FpisProgramFactorImpact[]
  awards            FpisProgramAward[]
  applicationWindows FpisApplicationWindow[]
  vdgTrackerEntries FpisVdgGrantTracker[]

  @@index([agency])
  @@index([programType])
  @@index([isActive])
}

model FpisProgramFactorImpact {
  id               String   @id @default(cuid())
  programId        String
  program          FpisProgram @relation(fields: [programId], references: [id])
  factorCode       String   @db.VarChar(5)         // FKB factor code (PLT, VRT, REG, etc.)
  pointsOnAward    Int      @db.SmallInt            // Score impact when awarded
  impactNote       String?  @db.Text               // Context for the point impact
  createdAt        DateTime @default(now())

  @@index([programId])
  @@index([factorCode])
}

model FpisProgramAward {
  id               String   @id @default(cuid())
  programId        String
  program          FpisProgram @relation(fields: [programId], references: [id])
  cityId           String?                         // Market that received the award
  awardee          String   @db.VarChar(200)       // Organization name
  awardAmount      Decimal? @db.Decimal(15, 2)
  awardDate        DateTime @db.Date
  projectTitle     String?  @db.VarChar(500)
  sourceUrl        String?  @db.Text               // USASpending.gov link or press release
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([programId])
  @@index([cityId])
  @@index([awardDate])
}

model FpisApplicationWindow {
  id               String   @id @default(cuid())
  programId        String
  program          FpisProgram @relation(fields: [programId], references: [id])
  fiscalYear       String   @db.VarChar(10)        // FY2026, FY2027
  openDate         DateTime? @db.Date
  closeDate        DateTime? @db.Date
  nofoUrl          String?  @db.Text               // Notice of Funding Opportunity link
  status           String   @db.VarChar(20)        // UPCOMING | OPEN | CLOSED | CANCELLED
  notes            String?  @db.Text
  createdAt        DateTime @default(now())

  @@index([programId])
  @@index([status])
}

model FpisVdgGrantTracker {
  id               String   @id @default(cuid())
  programId        String
  program          FpisProgram @relation(fields: [programId], references: [id])
  applicationName  String   @db.VarChar(200)       // "SC Launch", "AFWERX Phase I", etc.
  status           String   @db.VarChar(20)        // IDENTIFIED | DRAFTING | SUBMITTED | UNDER_REVIEW | AWARDED | DECLINED
  targetAmount     Decimal? @db.Decimal(15, 2)
  submittedDate    DateTime? @db.Date
  decisionDate     DateTime? @db.Date
  outcome          String?  @db.VarChar(20)        // AWARDED | DECLINED | WITHDRAWN
  nextAction       String?  @db.Text
  notes            String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([programId])
  @@index([status])
}

// ═══════════════════════════════════════════════════════════
// Terminology Database
// Source-traced, scoring-linked terminology reference.
// Public page at /terminology. Internal style guide.
// Every term traceable to a primary source document.
// ═══════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════
// Heliport Compliance Database
// 5-question compliance checklist per FAA-registered site.
// Output: COMPLIANT / CONDITIONAL / OBJECTIONABLE per site.
// Foundation for insurance portfolio product + VRT factor.
// ═══════════════════════════════════════════════════════════

model HeliportCompliance {
  id                    String   @id @default(cuid())
  facilityId            String   @unique               // FAA site number from NASR 5010
  facilityName          String   @db.VarChar(200)
  state                 String   @db.Char(2)
  city                  String   @db.VarChar(100)
  lat                   Decimal  @db.Decimal(9, 6)
  lng                   Decimal  @db.Decimal(9, 6)
  siteType              String   @db.VarChar(30)       // hospital | private | public | military | other
  ownershipType         String?  @db.VarChar(30)       // public | private | military

  // Question 1: FAA registration current and accurate
  q1FaaRegistration     String   @default("unknown")   // pass | flag | missing | unknown
  q1Note                String?  @db.Text

  // Question 2: FAA airspace determination on file
  q2AirspaceDetermination String @default("unknown")   // on_file | not_found | unknown
  q2DeterminationType   String?  @db.VarChar(20)       // concur | concur_with_exception | objectionable
  q2Note                String?  @db.Text

  // Question 3: State enforcement posture
  q3StateEnforcement    String   @default("unknown")   // strong | limited | none | unknown
  q3Note                String?  @db.Text

  // Question 4: NFPA 418 jurisdiction adoption
  q4Nfpa418             String   @default("unknown")   // adopted | partial | none | unknown
  q4Note                String?  @db.Text

  // Question 5: eVTOL dimensional viability
  q5EvtolViability      String   @default("unknown")   // viable | at_risk | unknown
  q5Note                String?  @db.Text

  // Computed compliance status
  complianceStatus      String   @default("unknown")   // compliant | conditional | objectionable | unknown
  complianceScore       Int      @default(0) @db.SmallInt // 0-5 (count of passing questions)
  flagCount             Int      @default(0) @db.SmallInt // Number of questions that failed

  // Metadata
  lastAssessedAt        DateTime? @db.Date
  assessedBy            String?  @db.VarChar(50)       // PIPELINE | ANALYST | REX
  marketId              String?                        // Nearest tracked market if within metro area
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([state])
  @@index([complianceStatus])
  @@index([siteType])
  @@index([marketId])
  @@index([q5EvtolViability])
}

model OeaaaDetermination {
  id                    String    @id @default(cuid())
  asn                   String    @unique                // Aeronautical Study Number — natural key
  caseId                String?
  caseType              String    @db.VarChar(10)        // OE | NRA
  statusCode            String    @db.VarChar(30)        // DET-DNE, DET-to-Prop, DET-Conditional, CIR, etc.
  nearestAirportName    String?   @db.VarChar(200)
  nearestCity           String    @db.VarChar(100)
  nearestState          String    @db.Char(2)
  lat                   Decimal   @db.Decimal(9, 6)
  lng                   Decimal   @db.Decimal(9, 6)
  structureType         String?   @db.VarChar(100)
  structureDescription  String?   @db.Text
  aglHeight             Int?                             // feet AGL
  amslHeight            Int?                             // feet AMSL
  filingDate            DateTime? @db.Date
  determinationDate     DateTime? @db.Date
  expirationDate        DateTime? @db.Date
  year                  Int       @db.SmallInt
  sourceEndpoint        String    @db.VarChar(30)        // NRA_state | CIRC_state | case_asn
  marketId              String?                          // Nearest tracked market if geo-matched
  linkedHeliportId      String?                          // Matched Heliport.id by proximity
  raw                   Json                             // Full parsed XML record for audit
  ingestedAt            DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([nearestState])
  @@index([statusCode])
  @@index([marketId])
  @@index([linkedHeliportId])
  @@index([year])
}

model AirIndexTerm {
  id                  String   @id                     // Slug format: "vertiport", "heliport", etc.
  term                String   @db.VarChar(200)        // The correct term as it appears in source
  definition          String   @db.Text                // Plain-language definition in AirIndex voice
  sourceRef           String   @db.VarChar(200)        // Primary source: "FAA AC 150/5390-2D", "14 CFR Part 157"
  sourceUrl           String?  @db.Text                // Direct URL to source document
  incorrectAlternatives String[] @default([])          // Common wrong terms: ["helipad", "landing pad"]
  contextOfUse        String   @db.Text                // Where/how this term should appear
  factorCodes         String[] @default([])            // AirIndex factor codes affected: ["LEG", "ZON", "VRT"]
  scoringImplication  String   @db.Text                // What happens to score when city uses wrong term
  category            String   @db.VarChar(30)         // infrastructure | regulatory | operational | legislative | standards
  versionAdded        String   @db.VarChar(10)         // AirIndex methodology version: "v1.3"
  lastUpdated         DateTime @db.Date
  isPublic            Boolean  @default(true)          // true = visible on /terminology
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([category])
  @@index([isPublic])
}

model RplAnalystAnnotation {
  id                  String   @id @default(cuid())
  documentId          String
  document            RplDocument @relation(fields: [documentId], references: [id])
  annotationType      String                     // CONTEXT | CORRECTION | PREDICTION | LINK
  content             String   @db.Text
  analystName         String
  createdAt           DateTime @default(now())

  @@index([documentId])
}

// ── Prediction Scorecard ─────────────────────────────────
//
// Logs every prediction the platform makes (Forward Signals output) so we
// can track accuracy over time. Without this, we can't claim "POSITIVE_WATCH
// markets gain X points within 90 days" — we'd be guessing.
//
// A prediction is logged when generated. Verification happens later via
// scripts/verify-predictions.ts (compares predicted outcome to actual state
// after the predicted window closes).

model PredictionRecord {
  id                  String   @id @default(cuid())
  cityId              String
  signalId            String                       // ID of the ForwardSignal that generated this prediction
  signalType          String                       // awaiting_decision | watch_trajectory | facility_milestone | etc.
  category            String                       // regulatory | operator | infrastructure | weather
  description         String   @db.Text

  // What was predicted
  predictedFactor     String?                      // ScoreBreakdown key, if score-impacting
  predictedDelta      Int      @default(0)         // expected score change
  predictedDirection  String                       // positive | negative | neutral
  confidence          String                       // high | medium | low

  // Window
  earliestExpected    DateTime?
  latestExpected      DateTime?
  windowLabel         String

  // Outcome (filled in by verification job)
  status              String   @default("pending") // pending | validated | invalidated | inconclusive | overdue
  actualOutcome       String?  @db.Text            // human-readable description of what actually happened
  actualDelta         Int?                         // measured score change
  verifiedAt          DateTime?
  verifiedBy          String?                      // PIPELINE | ANALYST

  // Provenance
  sourceRecordId      String?
  sourceUrl           String?
  generatedAt         DateTime @default(now())
  reportContext       String?                      // where this prediction was surfaced (gap_report | one_market_monday | api | etc.)

  @@index([cityId])
  @@index([status])
  @@index([signalType])
  @@index([generatedAt])
  @@index([latestExpected])
}

// ── TruWeather Deployment Data ────────────────────────────
//
// Stores TruWeather Solutions deployment map data for the partnership.
// Populated via scripts/ingest-truweather-deployment.ts when TruWeather
// provides its quarterly coverage map.
//
// Each record represents one sensor deployment. Multiple records per
// market are allowed (e.g., a metro with V360 at two vertiport locations).
//
// Consumed by calculateReadinessScoreV14() in src/lib/scoring.ts to
// compute the Low-Altitude Sensing sub-indicator (5 points max) under
// v1.4 scoring methodology.

model TruWeatherDeployment {
  id                 String    @id @default(cuid())
  marketId           String                          // AirIndex tracked market ID
  siteName           String?                         // specific facility, if known
  lat                Float?                          // optional — if known, used for radius checks
  lng                Float?
  status             String                          // "deployed" | "planned" | "none"
  deploymentDate     DateTime? @db.Date              // null if planned-only
  sensorType         String                          // e.g., "V360"
  coverageRadiusKm   Float                           // radius of valid sensor coverage
  altitudeMinFeet    Int                             // AGL minimum (typically 30)
  altitudeMaxFeet    Int                             // AGL maximum (typically 2000)
  notes              String?   @db.Text
  source             String                          // provenance (e.g., "TruWeather Q2 2026 map")
  sourceDate         DateTime  @db.Date              // when the source was issued
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([marketId])
  @@index([status])
  @@index([marketId, status])
}

// ── Pre-Dev Facility Status History ───────────────────
// Records status transitions for facilities in src/data/pre-development-facilities.ts.
// Populated by the snapshot cron: writes a new row only when the static catalog's
// status for a facility differs from the most recent recorded status.
// Enables verification of `facility_milestone` predictions (did the facility
// actually advance through a milestone within the predicted window?).
model PreDevFacilityStatusHistory {
  id          String   @id @default(cuid())
  facilityId  String                         // matches PRE_DEVELOPMENT_FACILITIES[].id
  marketId    String?                        // nearest AirIndex market, for convenience
  status      String                         // snapshot of FacilityStatus at recordedAt
  note        String?  @db.Text
  recordedAt  DateTime @default(now())

  @@index([facilityId, recordedAt])
  @@index([marketId])
}

// ── Grid Cells ────────────────────────────────────────
//
// 5-nautical-mile grid cells per tracked market. Each cell stores its
// bounding box, centroid, nearest-ASOS proximity, and coverage tier.
// Generated by scripts/generate-grid-prototype.ts (haversine distance
// to nearest ASOS station). Seeded from the existing JSON data under
// private/docs/grid/data/.
//
// Cells are the connective tissue between city-level scores and
// site-level scores. Consumed by:
//   - /admin/reports/grid/[cityId] — Don's grid-view demo surface
//   - v1.4 weather scoring (city score = mean of cell weather credits)
//   - RiskIndex site assessments (future: cell context for a facility)
//
// Scoring tiers (Don Berchoff's 5nm rule, FAA NPRM Part 108 pp. 96-98):
//   full    → centroid within 5nm of ASOS  → 5/5 credit
//   partial → centroid within 5–10nm       → 2/5 credit
//   none    → centroid beyond 10nm         → 0/5 credit

model GridCell {
  id                    String   @id                     // cellId: "miami_0_0"
  marketId              String                            // AirIndex tracked market ID
  row                   Int      @db.SmallInt
  col                   Int      @db.SmallInt

  // Cell bounds (WGS84)
  minLat                Float
  maxLat                Float
  minLng                Float
  maxLng                Float
  centroidLat           Float
  centroidLng           Float

  // Nearest ASOS station (populated by generator script)
  nearestAsosId         String?                           // ICAO ID, e.g., "KMIA"
  nearestAsosDistanceNm Float?                            // nautical miles

  // Scoring
  tier                  String   @db.VarChar(10)          // "full" | "partial" | "none"
  centroidCredit        Int      @db.SmallInt             // 0 | 2 | 5

  // Heliports / sites whose coordinates fall inside this cell.
  // Stored as array of FAA Heliport.id values (NASR 5010 identifiers).
  siteIds               String[]

  // Provenance
  gridVersion           String   @db.VarChar(20)          // e.g., "v1.4-preview"
  generatedAt           DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([marketId])
  @@index([marketId, tier])
  @@index([tier])
}

// ── Forward Signal Alert Log ──────────────────────────
// Tracks forward-signal alert emails sent per (user, city, predictionRecord).
// Lets the alert cron dedupe so a single prediction only triggers one email
// per subscriber. Primary key is the composite tuple via @@unique.
model ForwardSignalAlert {
  id                  String   @id @default(cuid())
  userId              String
  cityId              String
  predictionRecordId  String
  sentAt              DateTime @default(now())

  @@unique([userId, predictionRecordId])
  @@index([userId])
  @@index([cityId])
  @@index([sentAt])
}

// ── Briefing Send Log ─────────────────────────────────
// Tracks per-recipient briefing sends from scripts/send-briefing.ts so the
// follow-up drip cron can detect unopened briefings and fire a second-angle
// email. Open detection cross-references NewsletterEvent where
// series = briefing_<persona> and email matches.
model BriefingSend {
  id              String    @id @default(cuid())
  recipientEmail  String
  recipientName   String?
  persona         String                        // infrastructure | municipality | insurance | operator | investor
  cityId          String
  briefingUrl     String    @db.Text            // raw (untracked) briefing URL for follow-up body
  subject         String    @db.Text
  customMessage   String?   @db.Text            // custom message passed to send-briefing, if any
  sentAt          DateTime  @default(now())
  followUpSentAt  DateTime?                     // set when the drip fires
  followUpSkipped Boolean   @default(false)    // manual override to prevent follow-up

  @@index([recipientEmail])
  @@index([sentAt])
  @@index([followUpSentAt])
  @@index([persona, cityId])
}

// ── Outreach Contact Tracking ─────────────────────────
// Lightweight CRM for outbound BD touchpoints (Larry Mattiello intro,
// future operator/underwriter/investor conversations). Daily cron
// checks for stale entries and pings Alan when a follow-up is due.
// Not a full CRM — just enough to stop relying on email-thread memory.
model OutreachContact {
  id                 String    @id @default(cuid())
  name               String
  email              String
  org                String?
  title              String?
  referrer           String?                       // "Rex Alexander", "warm intro via X"
  firstEmailSentAt   DateTime
  firstEmailSubject  String    @db.Text
  briefingUrl        String?   @db.Text            // canonical demo URL shared (briefing, snapshot, etc.)
  replyReceivedAt    DateTime?
  followUpSentAt     DateTime?
  closedAt           DateTime?                     // set when the thread resolves (reply or explicit close)
  status             String    @default("awaiting_reply") // awaiting_reply | replied | declined | ghosted | active
  manualNote         String?   @db.Text
  lastReminderAt     DateTime?                     // set when cron pings Alan so we don't spam

  @@index([status])
  @@index([firstEmailSentAt])
  @@index([email])
}

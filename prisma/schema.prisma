datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Auth.js required models ─────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  stripeCustomerId      String?   @unique
  tier                  String    @default("free") // free|pro|institutional|enterprise|grandfathered
  accounts              Account[]
  sessions              Session[]
  subscriptions         Subscription[]
  billingSubscriptions  BillingSubscription[]
  watchlist             Watchlist?
  events                UserEvent[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── App models ──────────────────────────────────────────────

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  cityIds      String[]
  corridorIds  String[] @default([])
  changeTypes  String[]
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  cityIds   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoreSnapshot {
  id                String   @id @default(cuid())
  cityId            String
  score             Int
  breakdown         Json
  tier              String?  // "HIGH" | "MODERATE" | "EARLY" | "NASCENT"
  triggeringEventId String?  // links to ChangelogEntry.id
  filingIngestedAt  DateTime? // when the triggering filing was first ingested
  capturedAt        DateTime @default(now())

  @@index([cityId, capturedAt])
}

model ClassificationResult {
  id             String   @id @default(cuid())
  recordId       String   // IngestedRecord.id
  eventType      String   // from the event_type vocabulary
  factorsJson    Json     // full factors_affected array from Claude
  affectedCities String[] // city IDs identified
  confidence     String   // "high" | "medium" | "needs_review"
  rawResponse    Json     // full Claude API response for debugging
  modelUsed      String   // e.g. "claude-haiku-4-5-20251001"
  promptVersion  String   // version string for prompt tracking
  createdAt      DateTime @default(now())

  @@index([recordId])
  @@index([eventType])
  @@index([confidence])
}

model ChangelogEntry {
  id                String   @id @default(cuid())
  changeType        String   // "new_filing" | "status_change" | "new_law" | "faa_update" | "score_change"
  relatedEntityType String   // "city" | "vertiport" | "operator" | "corridor" | "filing"
  relatedEntityId   String
  summary           String
  sourceUrl         String?
  timestamp         DateTime @default(now())

  @@index([timestamp])
  @@index([changeType])
}

model Corridor {
  id                    String    @id // e.g. "cor_lax_dtla"
  name                  String
  status                String    // "proposed" | "authorized" | "active" | "suspended"
  cityId                String
  operatorId            String?
  startPointLat         Float
  startPointLng         Float
  startPointLabel       String
  endPointLat           Float
  endPointLng           Float
  endPointLabel         String
  waypoints             Json?     // Array of { lat, lng }
  distanceKm            Float
  estimatedFlightMinutes Int
  maxAltitudeFt         Int
  altitudeMinFt         Int?
  faaAuthNumber         String?
  effectiveDate         String?
  expirationDate        String?
  clearedOperators      String[]
  notes                 String?
  sourceUrl             String?
  lastUpdated           DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  statusHistory CorridorStatusHistory[]

  @@index([cityId])
  @@index([status])
  @@index([operatorId])
}

model CorridorStatusHistory {
  id          String    @id @default(cuid())
  corridorId  String
  fromStatus  String?
  toStatus    String
  reason      String?
  sourceUrl   String?
  changedAt   DateTime  @default(now())

  corridor    Corridor  @relation(fields: [corridorId], references: [id], onDelete: Cascade)

  @@index([corridorId, changedAt])
}

model UserEvent {
  id         String   @id @default(cuid())
  userId     String
  event      String   // "page_view" | "city_detail" | "corridor_click" | "tab_switch" | "report_download" | "operator_click"
  entityType String?  // "city" | "corridor" | "operator" | "page" | "tab" | "report"
  entityId   String?  // e.g. "los_angeles", "cor_mia_fll", "/methodology"
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([event])
  @@index([entityType, entityId])
}

model ScoringOverride {
  id             String    @id @default(cuid())
  cityId         String
  field          String    // scoring input name (e.g. "hasStateLegislation")
  value          Json      // the override value (e.g. true)
  reason         String
  sourceRecordId String?   // links to IngestedRecord.id
  sourceUrl      String?
  confidence     String    // "high" | "medium" | "needs_review"
  appliedAt      DateTime? // set when auto-applied
  supersededAt   DateTime? // set when a newer override replaces this one
  createdAt      DateTime  @default(now())

  @@index([cityId, field])
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  role      String?
  tier      String   // "pro" | "institutional" | "enterprise"
  message   String?
  createdAt DateTime @default(now())

  @@index([tier])
  @@index([email])
}

model BillingSubscription {
  id                    String    @id @default(cuid())
  userId                String
  stripeCustomerId      String
  stripeSubscriptionId  String    @unique
  stripePriceId         String
  tier                  String    // pro|institutional|enterprise
  status                String    // active|past_due|canceled|trialing|unpaid
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean   @default(false)
  canceledAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([status])
}

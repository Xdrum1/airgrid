datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ── Auth.js required models ─────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String    @unique
  emailVerified         DateTime?
  image                 String?
  stripeCustomerId      String?   @unique
  tier                  String    @default("free") // free|pro|institutional|enterprise|grandfathered
  role                  String?   // operator|investor|government|researcher|press|other
  accounts              Account[]
  sessions              Session[]
  subscriptions         Subscription[]
  billingSubscriptions  BillingSubscription[]
  watchlist             Watchlist?
  events                UserEvent[]
  apiKeys               ApiKey[]
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ── App models ──────────────────────────────────────────────

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  cityIds      String[]
  corridorIds  String[] @default([])
  changeTypes  String[]
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Watchlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  cityIds   String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ScoreSnapshot {
  id                String   @id @default(cuid())
  cityId            String
  score             Int
  breakdown         Json
  tier              String?  // "HIGH" | "MODERATE" | "EARLY" | "NASCENT"
  triggeringEventId String?  // links to ChangelogEntry.id
  filingIngestedAt  DateTime? // when the triggering filing was first ingested
  capturedAt        DateTime @default(now())

  @@index([cityId, capturedAt])
}

model ClassificationResult {
  id             String   @id @default(cuid())
  recordId       String   // IngestedRecord.id
  eventType      String   // from the event_type vocabulary
  factorsJson    Json     // full factors_affected array from Claude
  affectedCities String[] // city IDs identified
  confidence     String   // "high" | "medium" | "needs_review"
  rawResponse    Json     // full Claude API response for debugging
  modelUsed      String   // e.g. "claude-haiku-4-5-20251001"
  promptVersion  String   // version string for prompt tracking
  createdAt      DateTime @default(now())

  @@index([recordId])
  @@index([eventType])
  @@index([confidence])
}

model ChangelogEntry {
  id                String   @id @default(cuid())
  changeType        String   // "new_filing" | "status_change" | "new_law" | "faa_update" | "score_change"
  relatedEntityType String   // "city" | "vertiport" | "operator" | "corridor" | "filing"
  relatedEntityId   String
  summary           String
  sourceUrl         String?
  timestamp         DateTime @default(now())

  @@index([timestamp])
  @@index([changeType])
}

model Corridor {
  id                    String    @id // e.g. "cor_lax_dtla"
  name                  String
  status                String    // "proposed" | "authorized" | "active" | "suspended"
  cityId                String
  operatorId            String?
  startPointLat         Float
  startPointLng         Float
  startPointLabel       String
  endPointLat           Float
  endPointLng           Float
  endPointLabel         String
  waypoints             Json?     // Array of { lat, lng }
  distanceKm            Float
  estimatedFlightMinutes Int
  maxAltitudeFt         Int
  altitudeMinFt         Int?
  faaAuthNumber         String?
  effectiveDate         String?
  expirationDate        String?
  clearedOperators      String[]
  notes                 String?
  sourceUrl             String?
  lastUpdated           DateTime  @default(now())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  statusHistory CorridorStatusHistory[]

  @@index([cityId])
  @@index([status])
  @@index([operatorId])
}

model CorridorStatusHistory {
  id          String    @id @default(cuid())
  corridorId  String
  fromStatus  String?
  toStatus    String
  reason      String?
  sourceUrl   String?
  changedAt   DateTime  @default(now())

  corridor    Corridor  @relation(fields: [corridorId], references: [id], onDelete: Cascade)

  @@index([corridorId, changedAt])
}

model UserEvent {
  id         String   @id @default(cuid())
  userId     String
  event      String   // "page_view" | "city_detail" | "corridor_click" | "tab_switch" | "report_download" | "operator_click"
  entityType String?  // "city" | "corridor" | "operator" | "page" | "tab" | "report"
  entityId   String?  // e.g. "los_angeles", "cor_mia_fll", "/methodology"
  metadata   Json?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([event])
  @@index([entityType, entityId])
}

model ScoringOverride {
  id             String    @id @default(cuid())
  cityId         String
  field          String    // scoring input name (e.g. "hasStateLegislation")
  value          Json      // the override value (e.g. true)
  reason         String
  sourceRecordId String?   // links to IngestedRecord.id
  sourceUrl      String?
  confidence     String    // "high" | "medium" | "needs_review"
  appliedAt      DateTime? // set when auto-applied
  supersededAt   DateTime? // set when a newer override replaces this one
  createdAt      DateTime  @default(now())

  @@index([cityId, field])
}

model AutoReviewResult {
  id              String   @id @default(cuid())
  overrideId      String
  decision        String   // "approve" | "reject" | "skip"
  confidence      Float
  assignedCityId  String?  // city assigned for __unresolved__ overrides
  reasoning       String
  applied         Boolean  // whether the decision was actually applied
  dryRun          Boolean  @default(false)
  modelUsed       String
  sourceContent   String?  // truncated source text if fetched
  createdAt       DateTime @default(now())

  @@index([overrideId])
  @@index([decision])
  @@index([createdAt])
}

model ContactInquiry {
  id        String   @id @default(cuid())
  name      String
  email     String
  company   String?
  role      String?
  tier      String   // "pro" | "institutional" | "enterprise"
  message   String?
  createdAt DateTime @default(now())

  @@index([tier])
  @@index([email])
}

model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  name       String
  keyHash    String    @unique
  keyPrefix  String
  tier       String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BillingSubscription {
  id                    String    @id @default(cuid())
  userId                String
  stripeCustomerId      String
  stripeSubscriptionId  String    @unique
  stripePriceId         String
  tier                  String    // pro|institutional|enterprise
  status                String    // active|past_due|canceled|trialing|unpaid
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelAtPeriodEnd     Boolean   @default(false)
  canceledAt            DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
  @@index([status])
}

model IngestedRecord {
  id          String   @id // e.g. "federal_register_FR2023..."
  source      String   // "federal_register" | "legiscan" | "sec_edgar" | "operator_news"
  sourceId    String
  title       String
  summary     String
  status      String
  date        String
  url         String
  state       String?
  raw         Json
  ingestedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source])
}

model IngestionRun {
  id              String   @id @default(cuid())
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  newRecords      Int      @default(0)
  updatedRecords  Int      @default(0)
  unchangedCount  Int      @default(0)
  totalRecords    Int      @default(0)
  sources         String[] // ["federal_register", "legiscan", ...]
  overridesCreated Int     @default(0)
  overridesApplied Int     @default(0)
  scoreChanges    Int      @default(0)
  error           String?  // null = success, else error message
  alertSent       Boolean  @default(false)

  @@index([startedAt])
}

// ── Market Watch (ratings agency layer) ─────────────────────

model MarketWatch {
  id          String    @id @default(cuid())
  cityId      String    @unique
  watchStatus String    @default("STABLE") // STABLE | POSITIVE_WATCH | NEGATIVE_WATCH | DEVELOPING
  outlook     String    @default("STABLE") // IMPROVING | STABLE | DETERIORATING
  analystNote String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())

  history MarketWatchHistory[]

  @@index([watchStatus])
  @@index([published])
}

model MarketWatchHistory {
  id              String    @id @default(cuid())
  marketWatchId   String
  cityId          String
  fromWatchStatus String?
  toWatchStatus   String
  fromOutlook     String?
  toOutlook       String
  analystNote     String?
  reason          String
  source          String    @default("admin") // "admin" | "ai_suggested"
  suggestedBy     String?
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())

  marketWatch MarketWatch @relation(fields: [marketWatchId], references: [id], onDelete: Cascade)

  @@index([cityId, createdAt])
  @@index([marketWatchId])
}

model MarketWatchSuggestion {
  id               String   @id @default(cuid())
  cityId           String
  suggestedStatus  String
  suggestedOutlook String
  reasoning        String
  confidence       Float
  signalCount      Int
  status           String   @default("pending") // pending | accepted | dismissed
  createdAt        DateTime @default(now())

  @@index([cityId])
  @@index([status])
}

// ── Intel Feed ──────────────────────────────────────────

model FeedItem {
  id                     String    @id @default(cuid())
  title                  String
  summary                String    // 1-2 editorial sentences
  sourceUrl              String?
  category               String    // "Regulatory" | "Infrastructure" | "Operator" | "Legislative"
  cityIds                String[]  // tracked market city IDs
  scoreImpact            Boolean   @default(false)
  status                 String    @default("draft") // "draft" | "published" | "archived"
  promotedBy             String?   // "admin" | "auto"
  sourceRecordId         String?   // optional link to IngestedRecord.id
  classificationResultId String?   // optional link to ClassificationResult.id
  publishedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([status, publishedAt])
  @@index([category])
}

model MarketLead {
  id              String    @id @default(cuid())
  city            String    // e.g. "Columbus"
  state           String    // e.g. "OH"
  country         String    @default("US")
  source          String    // who tipped it — e.g. "Mike", "Rex", "SEC filing", "news"
  signal          String    // what they said / what was observed
  status          String    @default("new") // new | researching | verified | added | dismissed
  priority        String    @default("normal") // low | normal | high
  researchNotes   String?   // running notes on 7-factor research
  factorSnapshot  Json?     // partial scoring assessment: { hasStateLegislation: true, ... }
  addedAsCityId   String?   // set when graduated to live market (links to city id in seed)
  dismissedReason String?   // why it was dismissed
  signalCount     Int       @default(1)      // number of distinct signals accumulated
  lastSignalAt    DateTime? // when the most recent signal was detected
  signalSources   Json?     // array of { source, url, date, summary } for audit trail
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([city, state, country])
  @@index([status])
  @@index([priority])
}

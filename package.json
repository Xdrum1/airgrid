{
  "name": "airindex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:migrate:dev": "DATABASE_URL=postgresql://alanmichael@localhost:5432/airindex_dev npx prisma migrate dev",
    "db:studio:dev": "DATABASE_URL=postgresql://alanmichael@localhost:5432/airindex_dev npx prisma studio",
    "db:seed:dev": "DATABASE_URL=postgresql://alanmichael@localhost:5432/airindex_dev npx tsx prisma/seed-corridors.ts",
    "db:seed:snapshots": "DATABASE_URL=postgresql://alanmichael@localhost:5432/airindex_dev npx tsx prisma/seed-snapshots.ts",
    "dev:setup": "brew services start postgresql@16 && createdb airindex_dev 2>/dev/null; npm run db:migrate:dev && npm run db:seed:dev && echo 'Dev environment ready — run: npm run dev'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/client": "^6.19.2",
    "@sentry/nextjs": "^10.42.0",
    "@stripe/react-stripe-js": "^5.6.1",
    "@stripe/stripe-js": "^8.8.0",
    "@types/mapbox-gl": "^3.4.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.3",
    "date-fns": "^3.3.0",
    "fast-xml-parser": "^5.5.10",
    "mailchecker": "^6.0.20",
    "mapbox-gl": "^3.18.1",
    "next": "^15.5.12",
    "next-auth": "5.0.0-beta.30",
    "prisma": "^6.19.2",
    "react": "^19",
    "react-dom": "^19",
    "react-map-gl": "^7.1.7",
    "stripe": "^20.4.0",
    "ua-parser-js": "^2.0.9",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ua-parser-js": "^0.7.39",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10",
    "eslint": "^8",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8",
    "tailwindcss": "^3.4.0",
    "typescript": "^5",
    "vitest": "^3.2.4"
  }
}

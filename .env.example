# ============================================================
# AIRGRID — Environment Variables
# Copy this to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# App
NEXT_PUBLIC_APP_NAME=AirGrid
NEXT_PUBLIC_APP_VERSION=0.1.0

# Auth.js (next-auth v5)
# Generate with: npx auth secret
AUTH_SECRET=your_auth_secret_here
# AUTH_URL is intentionally omitted — trustHost in auth.ts auto-detects
# the correct URL from the request Host header (works for local + prod)

# FAA APIs (public, no key needed but rate limits apply)
FAA_API_BASE=https://uas-faa.opendata.arcgis.com

# Federal Register (public, no key needed)
FEDERAL_REGISTER_API=https://www.federalregister.gov/api/v1

# LegiScan - State legislature tracking
# Get free key at: https://legiscan.com/legiscan
LEGISCAN_API_KEY=your_key_here

# SEC EDGAR (public, no key — but must set User-Agent)
SEC_USER_AGENT=AirGrid your@email.com

# Mapbox - for the map visualization
# Get key at: https://mapbox.com (free tier is plenty for MVP)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# AWS SES — magic link + alert emails
SES_ACCESS_KEY_ID=your_ses_access_key_here
SES_SECRET_ACCESS_KEY=your_ses_secret_key_here
SES_REGION=us-east-1
SES_FROM_EMAIL=AirIndex <auth@yourdomain.com>
ADMIN_NOTIFY_EMAIL=you@yourdomain.com
ALERT_FROM_EMAIL=AirIndex <alerts@yourdomain.com>

# Cron secret — used to authenticate GET /api/ingest and GET /api/snapshot
CRON_SECRET=your_cron_secret_here

# Database (AWS RDS PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname
